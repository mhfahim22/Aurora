extern function memcmp(lhs: pointer, rhs: pointer, n: i64) -> i32
extern function memchr(ptr: pointer, value: i32, n: i64) -> pointer

extern function strlen(str: cstring) -> i64
extern function strcmp(lhs: cstring, rhs: cstring) -> i32
extern function strncmp(lhs: cstring, rhs: cstring, n: i64) -> i32
