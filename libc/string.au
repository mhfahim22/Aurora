extern function strncpy(dst: cstring, src: cstring, n: i64) -> cstring
extern function strcat(dst: cstring, src: cstring) -> cstring
extern function strncat(dst: cstring, src: cstring, n: i64) -> cstring
extern function strchr(str: cstring, ch: i32) -> cstring
extern function strrchr(str: cstring, ch: i32) -> cstring
extern function strstr(haystack: cstring, needle: cstring) -> cstring
extern function strspn(str: cstring, accept: cstring) -> i64
extern function strcspn(str: cstring, reject: cstring) -> i64
extern function strpbrk(str: cstring, accept: cstring) -> cstring
extern function strtok(str: cstring, delim: cstring) -> cstring
