module "game"

// ── Light Constants ──
const LIGHT_DIRECTIONAL := 0
const LIGHT_POINT       := 1
const LIGHT_SPOT        := 2
const LIGHT_AMBIENT     := 3

// ── Extern Functions (Lighting, 10) ──
extern function aurora_light_create(type: int, r: float, g: float, b: float, intensity: float): ptr
