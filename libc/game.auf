// ── Wrappers ──

// Lighting
pub fn light_create(type: int, r: float, g: float, b: float, intensity: float) -> ptr
    aurora_light_create(type, r, g, b, intensity)

pub fn light_destroy(light: ptr)
    aurora_light_destroy(light)

pub fn light_set_position(light: ptr, x: float, y: float, z: float)
    aurora_light_set_position(light, x, y, z)

pub fn light_set_direction(light: ptr, x: float, y: float, z: float)
    aurora_light_set_direction(light, x, y, z)

pub fn light_set_color(light: ptr, r: float, g: float, b: float)
    aurora_light_set_color(light, r, g, b)

pub fn light_set_intensity(light: ptr, intensity: float)
    aurora_light_set_intensity(light, intensity)

pub fn light_set_range(light: ptr, range: float)
    aurora_light_set_range(light, range)

pub fn light_set_spot_angle(light: ptr, inner: float, outer: float)
    aurora_light_set_spot_angle(light, inner, outer)

pub fn light_get_count() -> int
    aurora_light_get_count()

pub fn light_get(index: int) -> ptr
    aurora_light_get(index)

// Tilemap
pub fn tilemap_create(cols: int, rows: int, tile_w: int, tile_h: int, layers: int) -> ptr
    aurora_tilemap_create(cols, rows, tile_w, tile_h, layers)

pub fn tilemap_destroy(tm: ptr)
    aurora_tilemap_destroy(tm)

pub fn tilemap_set_tile(tm: ptr, col: int, row: int, layer: int, tile_id: int)
    aurora_tilemap_set_tile(tm, col, row, layer, tile_id)

pub fn tilemap_get_tile(tm: ptr, col: int, row: int, layer: int) -> int
    aurora_tilemap_get_tile(tm, col, row, layer)

pub fn tilemap_get_width(tm: ptr) -> int
    aurora_tilemap_get_width(tm)

pub fn tilemap_get_height(tm: ptr) -> int
    aurora_tilemap_get_height(tm)

pub fn tilemap_get_cols(tm: ptr) -> int
    aurora_tilemap_get_cols(tm)

pub fn tilemap_get_rows(tm: ptr) -> int
    aurora_tilemap_get_rows(tm)

pub fn tilemap_is_solid(tm: ptr, col: int, row: int, layer: int) -> int
    aurora_tilemap_is_solid(tm, col, row, layer)

pub fn tilemap_set_property(tm: ptr, key: str, value: str)
    aurora_tilemap_set_property(tm, key, value)

// Mesh
pub fn mesh_create_plane(width: float, depth: float) -> ptr
    aurora_mesh_create_plane(width, depth)

pub fn mesh_create_sphere(radius: float, segments: int) -> ptr
    aurora_mesh_create_sphere(radius, segments)

pub fn mesh_create_cylinder(radius: float, height: float, segments: int) -> ptr
    aurora_mesh_create_cylinder(radius, height, segments)

pub fn mesh_create_capsule(radius: float, height: float, segments: int) -> ptr
    aurora_mesh_create_capsule(radius, height, segments)

pub fn mesh_get_vertex_count(mesh: ptr) -> int
    aurora_mesh_get_vertex_count(mesh)

pub fn mesh_get_vertex_data(mesh: ptr) -> ptr
    aurora_mesh_get_vertex_data(mesh)

pub fn mesh_get_index_count(mesh: ptr) -> int
    aurora_mesh_get_index_count(mesh)

pub fn mesh_get_index_data(mesh: ptr) -> ptr
    aurora_mesh_get_index_data(mesh)

pub fn mesh_destroy(mesh: ptr)
    aurora_mesh_destroy(mesh)
