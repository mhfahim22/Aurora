## Unified Desktop App API
## Usage: import "app"
##
## Same code runs on Windows, Linux, macOS.
##
## Example:
##   import "app"
##   win = app_init("My App", 500, 400)
##   btn = app_button(win, "Click", 10, 10, 100, 30)
##   app_on_click(btn, fn() output("clicked!") end)
##   app_run(win)

## ── App Lifecycle ──

extern function aurora_app_init(title: cstring, w: i32, h: i32) -> pointer
extern function aurora_app_run(app: pointer)
extern function aurora_app_quit(app: pointer)

function app_init(title, w, h)
    return aurora_app_init(title, w, h)
end

function app_run(app)
    aurora_app_run(app)
end

function app_quit(app)
    aurora_app_quit(app)
end

## ── Windows ──

extern function aurora_app_window_new(app: pointer, title: cstring, x: i32, y: i32, w: i32, h: i32) -> pointer

function app_window_new(app, title, x, y, w, h)
    return aurora_app_window_new(app, title, x, y, w, h)
end

## ── Widgets ──

extern function aurora_app_button_new(parent: pointer, text: cstring, x: i32, y: i32, w: i32, h: i32) -> pointer
extern function aurora_app_label_new(parent: pointer, text: cstring, x: i32, y: i32, w: i32, h: i32) -> pointer
extern function aurora_app_textbox_new(parent: pointer, x: i32, y: i32, w: i32, h: i32) -> pointer
extern function aurora_app_listbox_new(parent: pointer, x: i32, y: i32, w: i32, h: i32) -> pointer
extern function aurora_app_checkbox_new(parent: pointer, text: cstring, x: i32, y: i32, w: i32, h: i32) -> pointer
extern function aurora_app_slider_new(parent: pointer, x: i32, y: i32, w: i32, h: i32, min: i32, max: i32) -> pointer
extern function aurora_app_progressbar_new(parent: pointer, x: i32, y: i32, w: i32, h: i32) -> pointer
extern function aurora_app_image_new(parent: pointer, path: cstring, x: i32, y: i32, w: i32, h: i32) -> pointer
extern function aurora_app_combobox_new(parent: pointer, x: i32, y: i32, w: i32, h: i32) -> pointer
extern function aurora_app_switch_new(parent: pointer, text: cstring, x: i32, y: i32, w: i32, h: i32) -> pointer

function app_button(parent, text, x, y, w, h)
    return aurora_app_button_new(parent, text, x, y, w, h)
end

function app_label(parent, text, x, y, w, h)
    return aurora_app_label_new(parent, text, x, y, w, h)
end

function app_textbox(parent, x, y, w, h)
    return aurora_app_textbox_new(parent, x, y, w, h)
end

function app_listbox(parent, x, y, w, h)
    return aurora_app_listbox_new(parent, x, y, w, h)
end

function app_checkbox(parent, text, x, y, w, h)
    return aurora_app_checkbox_new(parent, text, x, y, w, h)
end

function app_slider(parent, x, y, w, h, min, max)
    return aurora_app_slider_new(parent, x, y, w, h, min, max)
end

function app_progressbar(parent, x, y, w, h)
    return aurora_app_progressbar_new(parent, x, y, w, h)
end

function app_image(parent, path, x, y, w, h)
    return aurora_app_image_new(parent, path, x, y, w, h)
end

function app_combobox(parent, x, y, w, h)
    return aurora_app_combobox_new(parent, x, y, w, h)
end

function app_switch(parent, text, x, y, w, h)
    return aurora_app_switch_new(parent, text, x, y, w, h)
end

