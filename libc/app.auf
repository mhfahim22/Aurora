## ════════════════════════════════════════════════════════════
## Layout System — flexbox-style
## ════════════════════════════════════════════════════════════

## Layout: use aurora_app_layout_* directly from Aurora code.
## Navigation: use aurora_app_nav_* directly from Aurora code.
## Theme: use aurora_app_theme_* directly from Aurora code.

## ── Layout System ──
extern function aurora_app_layout_create() -> pointer
extern function aurora_app_layout_destroy(layout: pointer)
extern function aurora_app_layout_node_new(parent: pointer, type: i32) -> pointer
extern function aurora_app_layout_node_set_flex(node: pointer, grow: i32, shrink: i32, basis: i32)
extern function aurora_app_layout_node_set_direction(node: pointer, dir: i32)
extern function aurora_app_layout_node_set_justify(node: pointer, justify: i32)
extern function aurora_app_layout_node_set_align(node: pointer, align: i32)
extern function aurora_app_layout_node_set_wrap(node: pointer, wrap: i32)
extern function aurora_app_layout_node_set_gap(node: pointer, gap: f32)
extern function aurora_app_layout_node_set_size(node: pointer, w: f32, h: f32)
extern function aurora_app_layout_node_set_min_size(node: pointer, w: f32, h: f32)
extern function aurora_app_layout_node_set_max_size(node: pointer, w: f32, h: f32)
extern function aurora_app_layout_node_set_padding(node: pointer, l: f32, t: f32, r: f32, b: f32)
extern function aurora_app_layout_node_set_margin(node: pointer, l: f32, t: f32, r: f32, b: f32)
extern function aurora_app_layout_calculate(root: pointer, w: f32, h: f32)
extern function aurora_app_layout_node_get_x(node: pointer) -> f32
extern function aurora_app_layout_node_get_y(node: pointer) -> f32
extern function aurora_app_layout_node_get_w(node: pointer) -> f32
extern function aurora_app_layout_node_get_h(node: pointer) -> f32

