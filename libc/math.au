# ════════════════════════════════════════════════════════════
# Aurora Standard Library — Math
# Usage:  import "math"  or  import libc:math
#
# Builtins:
#   abs(x)     sqrt(x)     floor(x)    ceil(x)
#   round(x)   pow(x, y)   clamp(x, lo, hi)
#   rand()                  → random integer
#
# Conversion:
#   int(x), float(x), str(x), bool(x)
# ════════════════════════════════════════════════════════════
