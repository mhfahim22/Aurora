# ── GraphQL wrappers ──

function gql_schema_new():
    return aurora_gql_schema_new()
end

function gql_schema_free(schema):
    aurora_gql_schema_free(schema)
end

function gql_type_add_object(schema, name, description=""):
    return aurora_gql_type_add_object(schema, name, description) == 1
end

function gql_type_add_enum(schema, name, values_csv):
    return aurora_gql_type_add_enum(schema, name, values_csv) == 1
end

function gql_type_add_scalar(schema, name):
    return aurora_gql_type_add_scalar(schema, name) == 1
end

function gql_type_add_input(schema, name):
    return aurora_gql_type_add_input(schema, name) == 1
end

function gql_field_add(schema, type_name, field_name, field_type, description="", resolver=0, ctx=0):
    return aurora_gql_field_add(schema, type_name, field_name, field_type, description, resolver, ctx) == 1
end

function gql_query_add(schema, field_name, field_type, description="", resolver=0, ctx=0):
    return aurora_gql_query_add(schema, field_name, field_type, description, resolver, ctx) == 1
end

function gql_mutation_add(schema, field_name, field_type, description="", resolver=0, ctx=0):
    return aurora_gql_mutation_add(schema, field_name, field_type, description, resolver, ctx) == 1
end

function gql_execute(schema, query, variables_json="{}"):
    result = aurora_gql_execute(schema, query, variables_json)
    js = aurora_gql_result_json(result)
    aurora_gql_result_free(result)
    return js
end

function gql_parse_sdl(schema, sdl):
    return aurora_gql_parse_sdl(schema, sdl) == 1
end

function gql_introspect(schema):
    return aurora_gql_introspect(schema)
end

function gql_handle_request(schema, body_json):
    buf = cstring_repeat(65536)
    aurora_gql_handle_request(schema, body_json, buf, 65536)
    return buf
end

# ── API Gateway wrappers ──

function rate_limiter_new(max_requests=100, window_sec=60):
    return aurora_rate_limiter_new(max_requests, window_sec)
end

function rate_limiter_free(rl):
    aurora_rate_limiter_free(rl)
end

function rate_limiter_allow(rl, key):
    return aurora_rate_limiter_allow(rl, key) == 1
end

function rate_limiter_remaining(rl, key):
    return aurora_rate_limiter_remaining(rl, key)
end

function rate_limiter_reset(rl, key):
    aurora_rate_limiter_reset(rl, key)
end

function gateway_new(rl=0):
    return aurora_gateway_new(rl)
end

function gateway_free(gw):
    aurora_gateway_free(gw)
end

function gateway_add_route(gw, method, path, upstream_url):
    return aurora_gateway_add_route(gw, method, path, upstream_url) == 1
end

function gateway_remove_route(gw, method, path):
    return aurora_gateway_remove_route(gw, method, path) == 1
end

function gateway_forward(gw, method, path, body="", headers=""):
    buf = cstring_repeat(65536)
    n = aurora_gateway_forward(gw, method, path, body, headers, buf, 65536)
    if n < 0 return "" end
    return buf
end

function gateway_batch(gw, requests_json):
    buf = cstring_repeat(131072)
    n = aurora_gateway_batch(gw, requests_json, buf, 131072)
    if n < 0 return "" end
    return buf
end

function gateway_health(gw):
    buf = cstring_repeat(4096)
    aurora_gateway_health(gw, buf, 4096)
    return buf
end

function gateway_handle(gw, method, path, body="", headers="", client_ip=""):
    buf = cstring_repeat(65536)
    n = aurora_gateway_handle(gw, method, path, body, headers, client_ip, buf, 65536)
    if n < 0 return "" end
    return buf
end
