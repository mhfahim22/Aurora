## Aurora Standard Library — HTTP Server, TLS & WebSocket
## Usage:  import "server"
##
## Example:
##   import "server"
##   srv = server_init(8080)
##   server_enable_tls(srv, "cert.pem", "key.pem")
##   route_add(srv, "GET", "/hello", handler)
##   server_run(srv)
## ════════════════════════════════════════════════════════════

# ── Server lifecycle ──
extern function aurora_server_init(port: i64) -> pointer
extern function aurora_server_start(srv: pointer)
extern function aurora_server_stop(srv: pointer)
extern function aurora_server_start_with_pool(srv: pointer, router: pointer, pool_size: i32)
extern function aurora_server_enable_tls(srv: pointer, cert_path: cstring, key_path: cstring) -> i32

# ── Routing ──
extern function aurora_route_add(router: pointer, method: cstring, path_pattern: cstring, handler: pointer)
extern function aurora_route_register(method: cstring, path: cstring, handler: pointer)

# ── Run server ──
extern function aurora_server_accept_and_handle(srv: pointer, router: pointer)
extern function aurora_server_accept_loop(srv: pointer, router: pointer)

# ── Static file serving ──
extern function aurora_server_static(srv: pointer, prefix: cstring, directory: cstring)

# ── Simplified startup ──
extern function aurora_server_set_router(srv: pointer, router: pointer)
extern function aurora_server_run(srv: pointer)
extern function aurora_dev_server(port: i64, src_dir: cstring)

# ── WebSocket ──
extern function aurora_ws_is_upgrade(raw: cstring) -> i32
extern function aurora_ws_get_key(raw: cstring) -> cstring
extern function aurora_ws_upgrade(key: cstring, sock: i64, tls_handle: i64) -> i32
extern function aurora_ws_read_frame(sock: i64, tls_handle: i64, out_payload: pointer, out_opcode: pointer) -> i32
extern function aurora_ws_write_frame(sock: i64, tls_handle: i64, opcode: i32, data: pointer, len: i32) -> i32
extern function aurora_ws_close(sock: i64, tls_handle: i64)

# ── Raw TLS contexts (advanced) ──
extern function aurora_tls_server_ctx_new(cert_path: cstring, key_path: cstring) -> pointer
extern function aurora_tls_set_ca_chain(ctx: pointer, ca_path: cstring) -> i32
extern function aurora_tls_ctx_free(ctx: pointer)
extern function aurora_tls_accept(sock: i64, ctx: pointer) -> i64
extern function aurora_tls_read(tls_handle: i64, buf: pointer, size: i32) -> i32
extern function aurora_tls_write(tls_handle: i64, data: pointer, len: i32) -> i32
extern function aurora_tls_close(tls_handle: i64)

# ── WebSocket broadcast ──
extern function aurora_ws_registry_init()
extern function aurora_ws_registry_add(sock: i64, tls_handle: i64)
extern function aurora_ws_registry_remove(sock: i64)
extern function aurora_ws_broadcast(opcode: i32, data: pointer, len: i32) -> i32

