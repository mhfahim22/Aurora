# ════════════════════════════════════════════════════════════
# Aurora-level convenience wrappers
# ════════════════════════════════════════════════════════════

function server_init(port):
    return aurora_server_init(port)
end

function server_start(srv):
    aurora_server_start(srv)
end

function server_stop(srv):
    aurora_server_stop(srv)
end

function server_enable_tls(srv, cert_path, key_path):
    aurora_server_enable_tls(srv, cert_path, key_path)
end

function route_add(router, method, path, handler):
    aurora_route_add(router, method, path, handler)
end

function route_register(method, path, handler):
    aurora_route_register(method, path, handler)
end

function server_set_router(srv, router):
    aurora_server_set_router(srv, router)
end

function server_accept_and_handle(srv, router):
    aurora_server_accept_and_handle(srv, router)
end

function server_accept_loop(srv, router):
    aurora_server_accept_loop(srv, router)
end

function server_run(srv):
    aurora_server_run(srv)
end

function server_static(srv, prefix, directory):
    aurora_server_static(srv, prefix, directory)
end

function dev_server(port, src_dir):
    aurora_dev_server(port, src_dir)
end

function ws_is_upgrade(raw):
    return aurora_ws_is_upgrade(raw) != 0
end

function ws_get_key(raw):
    return aurora_ws_get_key(raw)
end

function ws_upgrade(key, sock, tls_handle):
    return aurora_ws_upgrade(key, sock, tls_handle) != 0
end

function ws_read_frame(sock, tls_handle):
    payload_ptr = alloc(8)
    opcode_ptr = alloc(4)
    len = aurora_ws_read_frame(sock, tls_handle, payload_ptr, opcode_ptr)
    return len, load(opcode_ptr, i32), load(payload_ptr, pointer)
end

function ws_write_frame(sock, tls_handle, opcode, data, len):
    aurora_ws_write_frame(sock, tls_handle, opcode, data, len)
end

function ws_close(sock, tls_handle):
    aurora_ws_close(sock, tls_handle)
end

function tls_server_ctx_new(cert_path, key_path):
    return aurora_tls_server_ctx_new(cert_path, key_path)
end

function tls_ctx_free(ctx):
    aurora_tls_ctx_free(ctx)
end

function tls_accept(ctx, sock):
    return aurora_tls_accept(sock, ctx)
end

function tls_read(handle, buf, size):
    return aurora_tls_read(handle, buf, size)
end

function tls_write(handle, data, len):
    return aurora_tls_write(handle, data, len)
end

function tls_close(handle):
    aurora_tls_close(handle)
end

function tls_set_ca_chain(ctx, ca_path):
    return aurora_tls_set_ca_chain(ctx, ca_path) != 0
end

function ws_registry_init():
    aurora_ws_registry_init()
end

function ws_broadcast_text(msg: cstring):
    return aurora_ws_broadcast(1, pointer_from_cstring(msg), len_cstring(msg))
end

function h2_is_upgrade(raw):
    return aurora_h2_is_upgrade(raw) != 0
end

function h2_new(sock, tls_handle=0, server_mode=1):
    return aurora_h2_new(sock, tls_handle, server_mode)
end

function h2_free(h2):
    aurora_h2_free(h2)
end

function h2_read_preface(h2):
    return aurora_h2_read_preface(h2) == 0
end

function h2_send_preface(h2):
    return aurora_h2_send_preface(h2) == 0
end

function h2_process_frames(h2):
    return aurora_h2_process_frames(h2) == 0
end

function h2_is_open(h2):
    return aurora_h2_is_open(h2) != 0
end

function h2_send_response(h2, stream_id, status_code, body="", content_type="text/plain"):
    headers = [content_type]
    return aurora_h2_send_response(h2, stream_id, status_code, headers, 1, body, len_cstring(body)) == 0
end

function h2_send_goaway(h2, error_code=0):
    return aurora_h2_send_goaway(h2, error_code) == 0
end

# ── SSE convenience ──
function sse_start(res):
    return aurora_sse_start(res) == 0
end

function sse_send(res, event, data):
    return aurora_sse_send_event(res, event, data) == 0
end

function sse_comment(res, comment):
    return aurora_sse_send_comment(res, comment) == 0
end

function sse_end(res):
    aurora_sse_end(res)
end

# ── Streaming convenience ──
function stream_start(res):
    return aurora_response_start_stream(res) == 0
end

function stream_chunk(res, data):
    return aurora_response_stream_chunk(res, data, len_cstring(data)) == 0
end

function stream_end(res):
    aurora_response_end_stream(res)
end

# ── Webhook convenience ──
function webhook_register(event, url, secret=""):
    return aurora_webhook_register(event, url, secret) == 0
end

function webhook_trigger(event, payload_json):
    return aurora_webhook_trigger(event, payload_json) == 0
end

function webhook_verify(payload, signature, secret):
    return aurora_webhook_verify(payload, signature, secret) != 0
end

# ── ORM convenience ──
function orm_schema(name):
    return aurora_orm_schema_define(name)
end

function orm_column(schema, name, type, flags=0, default_val=""):
    aurora_orm_schema_column(schema, name, type, flags, default_val)
end

function orm_create(db, schema, json_data):
    return aurora_orm_create(db, schema, json_data)
end

function orm_find(db, schema, id):
    return aurora_orm_find(db, schema, id)
end

function orm_all(db, schema):
    return aurora_orm_all(db, schema)
end

function orm_where(db, schema, conditions):
    return aurora_orm_where(db, schema, conditions)
end

function orm_update(db, schema, id, json_data):
    return aurora_orm_update(db, schema, id, json_data)
end

function orm_delete(db, schema, id):
    return aurora_orm_delete(db, schema, id)
end

function orm_count(db, schema):
    return aurora_orm_count(db, schema)
end

function orm_migrate(db, schema):
    return aurora_orm_auto_migrate(db, schema) == 0
end

function orm_schema_name(schema):
    return aurora_orm_schema_table_name(schema)
end

# ── REST convenience ──
function rest_register(router, db, schema, prefix=""):
    return aurora_rest_register(router, db, schema, prefix) == 0
end

function rest_set_hook(router, schema, hook_type, callback, user_data=0):
    return aurora_rest_set_hook(router, schema, hook_type, callback, user_data) == 0
end

# ── Security / hardening convenience ──
function add_security_headers(res):
    aurora_add_security_headers(res)
end

function rate_limit_check(key):
    return builtin_rate_limit_check(key) != 0
end

function csrf_verify(token):
    return builtin_csrf_verify(token) != 0
end

