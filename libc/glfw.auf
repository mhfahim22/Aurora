## ── Mouse buttons ──
GLFW_MOUSE_BUTTON_1 = 0
GLFW_MOUSE_BUTTON_2 = 1
GLFW_MOUSE_BUTTON_3 = 2
GLFW_MOUSE_BUTTON_LEFT   = 0
GLFW_MOUSE_BUTTON_RIGHT  = 1
GLFW_MOUSE_BUTTON_MIDDLE = 2

## ── Actions ──
GLFW_PRESS   = 1
GLFW_RELEASE = 0
GLFW_REPEAT  = 2

## ── Bool hints ──
GLFW_TRUE  = 1
GLFW_FALSE = 0

## ── Window hints ──
GLFW_RESIZABLE                = 0x00020003
GLFW_VISIBLE                  = 0x00020004
GLFW_DECORATED                = 0x00020005
GLFW_FOCUSED                  = 0x00020001
GLFW_AUTO_ICONIFY             = 0x00020006
GLFW_FLOATING                 = 0x00020007
GLFW_MAXIMIZED                = 0x00020008
GLFW_CENTER_CURSOR            = 0x00020009
GLFW_TRANSPARENT_FRAMEBUFFER  = 0x0002000A
GLFW_FOCUS_ON_SHOW            = 0x0002000B
GLFW_SCALE_TO_MONITOR         = 0x0002000C

## ── Context hints ──
GLFW_CONTEXT_VERSION_MAJOR    = 0x00022002
GLFW_CONTEXT_VERSION_MINOR    = 0x00022003
GLFW_CONTEXT_REVISION         = 0x00022004
GLFW_OPENGL_PROFILE           = 0x00022008
GLFW_OPENGL_CORE_PROFILE      = 0x00032001
GLFW_OPENGL_COMPAT_PROFILE    = 0x00032002
GLFW_OPENGL_FORWARD_COMPAT    = 0x00022006
GLFW_OPENGL_DEBUG_CONTEXT     = 0x00022007
GLFW_SAMPLES                  = 0x0002100D
GLFW_SRGB_CAPABLE             = 0x0002100E
GLFW_DOUBLEBUFFER             = 0x00021010
GLFW_CLIENT_API               = 0x00022001
GLFW_OPENGL_API               = 0x00030001
GLFW_OPENGL_ES_API            = 0x00030002
GLFW_NO_API                   = 0

## ── Modifier keys ──
GLFW_MOD_SHIFT     = 0x0001
GLFW_MOD_CONTROL   = 0x0002
GLFW_MOD_ALT       = 0x0004
GLFW_MOD_SUPER     = 0x0008
GLFW_MOD_CAPS_LOCK = 0x0010
GLFW_MOD_NUM_LOCK  = 0x0020

## ── Init hints ──
GLFW_JOYSTICK_HAT_BUTTONS = 0x00050001
GLFW_COCOA_CHDIR_RESOURCES= 0x00051001
GLFW_COCOA_MENUBAR        = 0x00051002

## ── Init/Terminate ──
extern "glfw3" function glfwInit() -> i32

extern "glfw3" function glfwTerminate()

extern "glfw3" function glfwGetVersion(major: pointer, minor: pointer, rev: pointer)

extern "glfw3" function glfwSetErrorCallback(cb: callback(i32, cstring)) -> pointer

## ── Window ──
extern "glfw3" function glfwCreateWindow(width: i32, height: i32, title: cstring, monitor: pointer, share: pointer) -> pointer

extern "glfw3" function glfwDestroyWindow(window: pointer)

extern "glfw3" function glfwSetWindowShouldClose(window: pointer, value: i32)

extern "glfw3" function glfwWindowShouldClose(window: pointer) -> i32

extern "glfw3" function glfwSetWindowTitle(window: pointer, title: cstring)

extern "glfw3" function glfwGetFramebufferSize(window: pointer, width: pointer, height: pointer)

extern "glfw3" function glfwGetWindowSize(window: pointer, width: pointer, height: pointer)

extern "glfw3" function glfwSetWindowSize(window: pointer, width: i32, height: i32)

extern "glfw3" function glfwGetWindowPos(window: pointer, xpos: pointer, ypos: pointer)

extern "glfw3" function glfwSetWindowPos(window: pointer, xpos: i32, ypos: i32)

extern "glfw3" function glfwHideWindow(window: pointer)

extern "glfw3" function glfwShowWindow(window: pointer)

extern "glfw3" function glfwFocusWindow(window: pointer)

extern "glfw3" function glfwWindowHint(hint: i32, value: i32)

## ── Window callbacks ──
extern "glfw3" function glfwSetWindowSizeCallback(window: pointer, cb: callback(pointer, i32, i32)) -> pointer

extern "glfw3" function glfwSetFramebufferSizeCallback(window: pointer, cb: callback(pointer, i32, i32)) -> pointer

extern "glfw3" function glfwSetWindowCloseCallback(window: pointer, cb: callback(pointer)) -> pointer

extern "glfw3" function glfwSetWindowPosCallback(window: pointer, cb: callback(pointer, i32, i32)) -> pointer

extern "glfw3" function glfwSetWindowFocusCallback(window: pointer, cb: callback(pointer, i32)) -> pointer

extern "glfw3" function glfwSetWindowIconifyCallback(window: pointer, cb: callback(pointer, i32)) -> pointer

## ── OpenGL context ──
extern "glfw3" function glfwMakeContextCurrent(window: pointer)

extern "glfw3" function glfwGetCurrentContext() -> pointer

extern "glfw3" function glfwSwapBuffers(window: pointer)

extern "glfw3" function glfwSwapInterval(interval: i32)

extern "glfw3" function glfwExtensionSupported(extension: cstring) -> i32

extern "glfw3" function glfwGetProcAddress(name: cstring) -> pointer

## ── Input ──
extern "glfw3" function glfwPollEvents()

extern "glfw3" function glfwWaitEvents()

extern "glfw3" function glfwGetKey(window: pointer, key: i32) -> i32

extern "glfw3" function glfwGetMouseButton(window: pointer, button: i32) -> i32

extern "glfw3" function glfwGetCursorPos(window: pointer, xpos: pointer, ypos: pointer)

extern "glfw3" function glfwSetCursorPos(window: pointer, xpos: f64, ypos: f64)

## ── Input callbacks ──
extern "glfw3" function glfwSetKeyCallback(window: pointer, cb: callback(pointer, i32, i32, i32, i32)) -> pointer

extern "glfw3" function glfwSetMouseButtonCallback(window: pointer, cb: callback(pointer, i32, i32, i32)) -> pointer

extern "glfw3" function glfwSetCursorPosCallback(window: pointer, cb: callback(pointer, f64, f64)) -> pointer

extern "glfw3" function glfwSetScrollCallback(window: pointer, cb: callback(pointer, f64, f64)) -> pointer

extern "glfw3" function glfwSetCharCallback(window: pointer, cb: callback(pointer, i32)) -> pointer

## ── Cursor mode ──
extern "glfw3" function glfwSetInputMode(window: pointer, mode: i32, value: i32)

GLFW_CURSOR               = 0x00033001
GLFW_STICKY_KEYS          = 0x00033002
GLFW_STICKY_MOUSE_BUTTONS = 0x00033003
GLFW_LOCK_KEY_MODS        = 0x00033004
GLFW_RAW_MOUSE_MOTION     = 0x00033005

GLFW_CURSOR_NORMAL   = 0x00034001
GLFW_CURSOR_HIDDEN   = 0x00034002
GLFW_CURSOR_DISABLED = 0x00034003

## ── Time ──
extern "glfw3" function glfwGetTime() -> f64

extern "glfw3" function glfwSetTime(time: f64)

## ── Monitor ──
extern "glfw3" function glfwGetPrimaryMonitor() -> pointer

extern "glfw3" function glfwGetVideoMode(monitor: pointer) -> pointer

extern "glfw3" function glfwSetWindowMonitor(window: pointer, monitor: pointer, xpos: i32, ypos: i32, width: i32, height: i32, refreshRate: i32)

## ── Clipboard ──
extern "glfw3" function glfwSetClipboardString(window: pointer, string: cstring)

extern "glfw3" function glfwGetClipboardString(window: pointer) -> cstring
