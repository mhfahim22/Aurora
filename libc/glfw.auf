## GLFW 3 — Windowing, Context, Input
## Usage: import "glfw"
## Requires: glfw3.dll (Windows), libglfw.so (Linux), libglfw.dylib (macOS)
## Download: https://www.glfw.org/download

## ── Version ──
GLFW_VERSION_MAJOR = 3
GLFW_VERSION_MINOR = 4
GLFW_VERSION_REVISION = 0

## ── Key codes ──
GLFW_KEY_UNKNOWN     = -1
