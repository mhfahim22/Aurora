# ════════════════════════════════════════════════════════════
# Aurora Integration Test — Parser Syntax Features
# ════════════════════════════════════════════════════════════

# ── 1. Variables & Arithmetic ──
x = 42
f = 3.14
s = "hello"
output(x)
output(f)
output(s)

a = 10 + 20 * 3
output(a)

# ── 2. Comparison & Logical ──
output(10 > 5)
output(10 == 10)
output(1 and 1)
output(0 or 1)

# ── 3. If / Elseif / Else ──
grade = 85
if grade >= 90
    output("A")
elseif grade >= 80
    output("B")
elseif grade >= 70
    output("C")
else
    output("F")

# ── 4. While Loop ──
sum = 0
i = 1
while i <= 10
    sum = sum + i
    i = i + 1
output(sum)

# ── 5. For Loop ──
for j in 5
    output(j)

# ── 6. Functions & Recursion ──
function fib(n)
    if n <= 1
        return n
    return fib(n - 1) + fib(n - 2)

output(fib(0))
output(fib(1))
output(fib(10))

# ── 7. Arrays ──
arr = [10, 20, 30, 40, 50]
output(arr[0])
output(arr[4])
arr[2] = 99
output(arr[2])

# ── 8. String Concatenation ──
greeting = "Hello" + " " + "World"
output(greeting)

# ── 9. Nested Arrays ──
matrix = [[1, 2], [3, 4], [5, 6]]
output(matrix[0])
output(matrix[2])
