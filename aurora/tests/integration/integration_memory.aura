# ════════════════════════════════════════════════════════════
# Aurora Integration Test — Memory Management
# ════════════════════════════════════════════════════════════

# ── 1. Array Copy ──
arr1 = [1, 2, 3]
arr2 = copy arr1
arr2[0] = 99
output(arr1[0])
output(arr2[0])

# ── 2. Array Free ──
temp = [10, 20, 30]
output(temp[0])
free temp

# ── 3. Array Operations ──
nums = [5, 3, 1, 4, 2]
total = 0
for i in 5
    total = total + nums[i]
output(total)

# ── 4. Nested Array ──
nested = [[1, 2], [3, 4]]
output(nested[0])
output(nested[1])

# ── 5. String Array ──
words = ["hello", "world", "aurora"]
for i in 3
    output(words[i])

# ── 6. Mixed Type Array ──
mixed = [1, 2.5, "text", true]
output(mixed[0])
output(mixed[2])
output(mixed[3])

# ── 7. Array in Function ──
function sum_array(arr, n)
    total = 0
    for i in n
        total = total + arr[i]
    return total

data = [10, 20, 30]
output(sum_array(data, 3))

# ── 8. Array as Return Value ──
function make_range(n)
    result = [0, 0, 0, 0, 0]
    for i in n
        result[i] = i * i
    return result

squares = make_range(5)
output(squares[0])
output(squares[4])
