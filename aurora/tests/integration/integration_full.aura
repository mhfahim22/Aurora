# ══════════════════════════════════
# Aurora Language — Complete Integration Test
# ══════════════════════════════════

# ── 1. Variables & Types ──
x = 42
f = 3.14
s = "Aurora"
output("--- Variables ---")
output(x)
output(f)
output(s)

# ── 2. Arithmetic ──
output("--- Arithmetic ---")
output(x + 8)
output(x - 2)
output(x * 2)
output(x / 5)
output(x % 5)
output(2 ** 10)
output(f + 1.0)
output(f * 2.0)

# ── 3. String Concatenation ──
output("--- Strings ---")
a = "Hello"
b = " World"
output(a + b)
output("Foo" + "Bar")

# ── 4. Comparison & Logic ──
output("--- Logic ---")
output(10 > 5)
output(10 < 5)
output(10 == 10)
output(10 != 5)
output(1 and 1)
output(1 and 0)
output(0 or 1)
output(0 or 0)
output(6 ^ 3)

# ── 5. If / Elseif / Else ──
output("--- Control Flow ---")
n = 75
if n > 100
    output("big")
elseif n > 50
    output("medium")
else
    output("small")

# ── 6. While Loop ──
output("--- While ---")
i = 0
while i < 3
    output(i)
    i = i + 1

# ── 7. For Loop ──
output("--- For ---")
for j in 4
    output(j)

# ── 8. Functions ──
output("--- Functions ---")
function add(a, b)
    return a + b

function multiply(a, b)
    return a * b

output(add(10, 20))
output(multiply(6, 7))

# ── 9. Recursion ──
output("--- Recursion ---")
function factorial(n)
    if n <= 1
        return 1
    return n * factorial(n - 1)

output(factorial(5))
output(factorial(10))

# ── 10. Arrays ──
output("--- Arrays ---")
arr = [1, 2, 3, 4, 5]
output(arr[0])
output(arr[4])
nums = [10, 20, 30]
total = 0
for k in 3
    total = total + nums[k]
output(total)

# ── 11. Builtins ──
output("--- Builtins ---")
output(len([1, 2, 3]))
output(sum([10, 20, 30]))
output(min([5, 2, 8]))
output(max([5, 2, 8]))

# ── 12. Nested Scopes ──
output("--- Scopes ---")
if 1
    scoped = 99
    output(scoped)

# ── 13. Early Return ──
output("--- Early Return ---")
function get_val(flag)
    if flag > 0
        return 10
    return 20

output(get_val(1))
output(get_val(0))

output("--- DONE ---")
