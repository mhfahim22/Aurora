# ════════════════════════════════════════════════════════════
# Aurora Integration Test — Exception Handling
# Tests: try/catch, throw, finally
# ════════════════════════════════════════════════════════════

# ── 1. Basic Try/Catch ──
try
    output("before throw")
    throw 42
    output("after throw - should not print")
catch
    output("caught exception")

# ── 2. Try/Catch with Value ──
try
    throw 100
catch
    output(__exception__)

# ── 3. Try/Catch/Finally ──
try
    throw 1
catch
    output("in catch")
finally
    output("in finally")

# ── 4. No Exception ──
try
    output("no exception here")
catch
    output("should not print")
finally
    output("finally runs anyway")

# ── 5. Nested Try/Catch ──
try
    try
        throw 10
    catch
        output("inner catch")
    output("between try blocks")
catch
    output("outer catch")
finally
    output("outer finally")

# ── 6. Function with Try/Catch ──
function safe_div(a, b)
    if b == 0
        throw 0
    return a / b

output(safe_div(10, 2))   # 5

try
    output(safe_div(10, 0))
catch
    output("division by zero")

# ── 7. Throw String ──
try
    throw 0
catch
    output("caught zero")
