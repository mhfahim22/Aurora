# Parser statement tests

function test_if()
    x = 5
    if x > 0
        output(1)
    else
        output(0)

function test_if_elif()
    x = 2
    if x == 1
        output(0)
    elseif x == 2
        output(1)
    else
        output(0)

function test_while()
    i = 0
    total = 0
    while i < 5
        total = total + i
        i = i + 1
    output(total == 10)

function test_for()
    total = 0
    for i in 5
        total = total + i
    output(total == 10)

function test_nested()
    total = 0
    for i in 3
        for j in 3
            total = total + 1
    output(total == 9)

function test_fib()
    n = 10
    a = 0
    b = 1
    for i in n
        c = a + b
        a = b
        b = c
    output(a == 55)

function test_double()
    output(5 * 2 == 10)

function test_braces()
    if true
        output(1)

function test_switch()
    x = 2
    if x == 1
        output(0)
    elseif x == 2
        output(1)
    else
        output(0)

output(0)
test_if()
test_if_elif()
test_while()
test_for()
test_nested()
test_fib()
test_double()
test_braces()
test_switch()
output("PARSER_STMT_OK")
