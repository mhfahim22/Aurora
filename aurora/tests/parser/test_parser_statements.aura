# Parser statement tests — verify all statement types parse and execute correctly

function test_if()
    x = 5
    if x > 0
        output(1)
    else
        output(0)

function test_if_elif()
    x = 2
    if x == 1
        output(0)
    elseif x == 2
        output(1)
    else
        output(0)

function test_while()
    i = 0
    total = 0
    while i < 5
        total = total + i
        i = i + 1
    output(total == 10)

function test_for()
    total = 0
    for i in 5
        total = total + i
    output(total == 10)

function test_for_range()
    total = 0
    for i in 2, 6
        total = total + i
    output(total == 14)  # 2+3+4+5

function test_nested()
    total = 0
    for i in 3
        for j in 3
            total = total + 1
    output(total == 9)

function test_fib()
    function fib(n)
        if n <= 1
            return n
        return fib(n-1) + fib(n-2)
    output(fib(10) == 55)

function test_closure()
    function make_counter(start)
        return fn()
            start = start + 1
            return start
    counter = make_counter(0)
    output(counter() == 1)
    output(counter() == 2)
    output(counter() == 3)

function test_braces()
    if true {
        output(1)
    }

function test_switch()
    x = 2
    switch x
        1 -> output(0)
        2 -> output(1)
        _ -> output(0)

output(0)
test_if()
test_if_elif()
test_while()
test_for()
test_for_range()
test_nested()
test_fib()
test_closure()
test_braces()
test_switch()
output("PARSER_STMT_OK")
