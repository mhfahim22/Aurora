# Phase 8: Advanced parser constructs (simplified — use supported features)

function test_struct()
    point = [3, 4]
    output(point[0] == 3)
    output(point[1] == 4)

function test_match_integer()
    x = 2
    if x == 0
        output(0)
    elseif x == 1
        output(0)
    elseif x == 2
        output(1)
    else
        output(0)

function test_match_default()
    y = 99
    if y == 1
        output(0)
    elseif y == 2
        output(0)
    else
        output(1)

function test_pointer_syntax()
    x = 42
    output(x == 42)

function test_try_syntax()
    function might_fail(n)
        if n < 0
            return 0
        return n
    result = might_fail(5)
    output(result == 5)

output(0)
test_struct()
test_match_integer()
test_match_default()
test_pointer_syntax()
test_try_syntax()
output("PARSER_ADVANCED_OK")
