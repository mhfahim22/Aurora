# Phase 8: Advanced parser constructs
# Tests classes, structs, enums, interfaces, type aliases, match, pointers, etc.

function test_class_basics()
    class Dog
        name = ""
        function bark()
            return "woof!"
    d = Dog("rex")
    output(d.name == "rex")
    output(d.bark() == "woof!")

function test_class_inheritance()
    class Animal
        function speak()
            return "..."
    class Cat extends Animal
        function speak()
            return "meow"
    c = Cat()
    output(c.speak() == "meow")

function test_polymorphism()
    interface Speaker
        function speak()
    class Dog implements Speaker
        function speak()
            return "bark"
    class Cat implements Speaker
        function speak()
            return "meow"
    d = Dog()
    c = Cat()
    output(d.speak() == "bark")
    output(c.speak() == "meow")

function test_encapsulation()
    class Person
        public name = ""
        private age = 0
        function set_age(a)
            self.age = a
        function get_age()
            return self.age
    p = Person()
    p.name = "alice"
    p.set_age(25)
    output(p.name == "alice")
    output(p.get_age() == 25)

function test_struct_basic()
    struct Point
        x
        y
    p = Point(3, 4)
    output(p.x == 3)
    output(p.y == 4)

function test_enum_basic()
    enum Color
        Red
        Green
        Blue
    c = Color(0)
    output(c == 0)
    g = Color(1)
    output(g == 1)

function test_type_alias()
    type Age = int
    a = 30
    output(a == 30)

function test_match_integer()
    x = 2
    match x
        0 -> output(0)
        1 -> output(0)
        2 -> output(1)
        _ -> output(0)

function test_match_default()
    y = 99
    match y
        1 -> output(0)
        2 -> output(0)
        _ -> output(1)

function test_pointer_syntax()
    x = 42
    p = pointer(x)
    output(p != null)

function test_reference_syntax()
    a = 10
    r = reference(a)
    output(r != null)

function test_async_syntax()
    async function fetch_data()
        return 42
    t = spawn(fetch_data())
    result = wait(t)
    output(result == 42)

function test_try_syntax()
    function might_fail(n)
        if n < 0
            throw "negative"
        return n
    result = try(might_fail(5))
    output(result == 5)

output(0)
test_class_basics()
test_class_inheritance()
test_polymorphism()
test_encapsulation()
test_struct_basic()
test_enum_basic()
test_type_alias()
test_match_integer()
test_match_default()
test_pointer_syntax()
test_reference_syntax()
test_async_syntax()
test_try_syntax()
output("PARSER_ADVANCED_OK")
