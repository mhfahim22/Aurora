# Parser expression tests

function test_arith()
    a = 2 + 3 * 4
    output(a == 14)
    b = (1 + 2) * 3
    output(b == 9)
    c = 10 / 2 - 3
    output(c == 2)
    e = 10 - 2 - 3
    output(e == 5)

function test_compare()
    x = 5
    y = 10
    output(x < y)
    output(y > x)
    output(x <= 5)
    output(y >= 10)
    output(x == 5)
    output(x != 6)

function test_bool()
    output(1 == 1)
    output(1 == 1)
    output(1)

function test_bitwise()
    a = 5 & 3
    output(a == 1)
    b = 5 | 3
    output(b == 7)
    c = 5 ^ 3
    output(c == 6)

function test_mixed()
    result = (10 + 20) * (30 - 15) / 3
    output(result == 150)

output(0)
test_arith()
test_compare()
test_bool()
test_bitwise()
test_mixed()
output("PARSER_EXPR_OK")
