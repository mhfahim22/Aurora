## Test: assertion library + test runner
import libc:test

function main()
    test_begin("assertion tests")
    assert_true(true)
    test_pass("assert_true")
    assert_false(false)
    test_pass("assert_false")
    assert_equal(42, 42)
    test_pass("assert_equal")
    assert_not_equal(1, 2)
    test_pass("assert_not_equal")
    assert_greater(5, 3)
    test_pass("assert_greater")
    assert_less(3, 5)
    test_pass("assert_less")
    assert_contains("hello world", "world")
    test_pass("assert_contains")
    assert_not_contains("hello world", "xyz")
    test_pass("assert_not_contains")
    assert_near(3.14159, 3.1416, 0.001)
    test_pass("assert_near")
    assert_null(0)
    test_pass("assert_null")
    assert_not_null(42)
    test_pass("assert_not_null")
    assert_match("hello world", "world")
    test_pass("assert_match")
    test_report()
end
