# Lexer keyword tests — verify all language keywords tokenize correctly
function test_keywords()
    if true
        output(1)
    else
        output(0)
    while false
        output(0)
    for i in 1
        output(1)
    return 0

function test_more_keywords()
    class A
        pass
    match 1
        _ -> output(1)
    break
    continue

output(0)
test_keywords()
test_more_keywords()
output("LEXER_KEYWORDS_OK")
