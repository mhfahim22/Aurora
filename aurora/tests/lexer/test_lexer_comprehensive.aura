# Phase 8: Comprehensive lexer test via full compilation pipeline

function test_operators()
    a = 2 + 3
    output(a == 5)
    b = 10 - 4
    output(b == 6)
    c = 3 * 7
    output(c == 21)
    d = 20 / 5
    output(d == 4)
    f = 17 % 5
    output(f == 2)

function test_bitwise()
    a = 5 & 3
    output(a == 1)
    b = 5 | 3
    output(b == 7)
    c = 5 ^ 3
    output(c == 6)

function test_comparison()
    output(1 == 1)
    output(1 != 2)
    output(1 < 2)
    output(2 > 1)
    output(1 <= 1)
    output(2 >= 2)

function test_string()
    s = "hello"
    output(s == "hello")
    s = "hello\nworld"
    output(s != null)
    t = "single\tquotes"
    output(t != null)

function test_complex_expr()
    result = (1 + 2) * (3 + 4) / (5 - 2) + 8
    output(result >= 0)

function test_identifiers()
    camelCase = 1
    snake_case = 2
    _private = 3
    ALL_CAPS = 4
    output(camelCase == 1)
    output(snake_case == 2)
    output(_private == 3)
    output(ALL_CAPS == 4)

output(0)
test_operators()
test_bitwise()
test_comparison()
test_string()
test_complex_expr()
test_identifiers()
output("LEXER_FULL_OK")
