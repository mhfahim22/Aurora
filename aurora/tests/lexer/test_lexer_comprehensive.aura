# Phase 8: Comprehensive lexer test via full compilation pipeline
# Tests that complex expressions with various tokens compile and compute correctly

function test_operators()
    a = 2 + 3
    output(a == 5)
    b = 10 - 4
    output(b == 6)
    c = 3 * 7
    output(c == 21)
    d = 20 / 5
    output(d == 4)
    e = 2 ** 10
    output(e == 1024)
    f = 17 % 5
    output(f == 2)

function test_bitwise()
    a = 5 & 3    # bitwise AND -> 1
    output(a == 1)
    b = 5 | 3    # bitwise OR -> 7
    output(b == 7)
    c = 5 ^ 3    # bitwise XOR -> 6
    output(c == 6)
    d = 1 << 3   # left shift -> 8
    output(d == 8)
    e = 16 >> 2  # right shift -> 4
    output(e == 4)

function test_comparison()
    output(1 == 1)
    output(1 != 2)
    output(1 < 2)
    output(2 > 1)
    output(1 <= 1)
    output(2 >= 2)

function test_attributes()
    @stack
    x = 42
    output(x == 42)
    
    @arena
    y = [1, 2, 3]
    output(y[0] == 1)
    
    @raii
    z = "hello"
    output(z == "hello")

function test_string_escapes()
    s = "hello\nworld"
    output(s != null)
    t = 'single\tquotes'
    output(t != null)

function test_complex_expr()
    result = (1 + 2) * (3 + 4) / (5 - 2) + (8 >> 2) & 7
    output(result >= 0)

function test_multi_line()
    x = <<
        1
        2
        3
    >>
    output(x[0] == 1)
    output(x[1] == 2)
    output(x[2] == 3)

function test_block_comment()
    /* This is a
       multi-line block comment */
    x = 99
    output(x == 99)

function test_identifiers()
    camelCase = 1
    snake_case = 2
    _private = 3
    ALL_CAPS = 4
    output(camelCase == 1)
    output(snake_case == 2)
    output(_private == 3)
    output(ALL_CAPS == 4)

output(0)
test_operators()
test_bitwise()
test_comparison()
test_attributes()
test_string_escapes()
test_complex_expr()
test_multi_line()
test_block_comment()
test_identifiers()
output("LEXER_FULL_OK")
