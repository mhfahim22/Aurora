# ════════════════════════════════════════════════════════════
# Aurora Complete Feature Test
# Tests: for-in, compound assign, catch(err), optimizer
# ════════════════════════════════════════════════════════════

# ── 1. For-in array iteration ──
arr = [10, 20, 30, 40, 50]
total = 0
for x in arr
    total = total + x
outputf("Array sum: %d\n", total)

# ── 2. For-in count ──
count = 0
for i in 5
    count = count + 1
outputf("Count: %d\n", count)

# ── 3. Compound assignment ──
x = 10
x += 5
outputf("x += 5: %d\n", x)
x -= 3
outputf("x -= 3: %d\n", x)
x *= 2
outputf("x *= 2: %d\n", x)
x /= 4
outputf("x /= 4: %d\n", x)

# ── 4. Catch(err) variable ──
try
    throw 42
catch err
    outputf("Caught: %d\n", err)

# ── 5. Optimizer: constant folding ──
outputf("2 + 3 = %d\n", 2 + 3)
outputf("10 * 5 = %d\n", 10 * 5)
outputf("100 / 10 = %d\n", 100 / 10)

# ── 6. Combined features ──
nums = [5, 3, 1, 4, 2]
sorted_arr = [0, 0, 0, 0, 0]
for i in 5
    sorted_arr[i] = nums[i]

max_val = sorted_arr[0]
for x in sorted_arr
    if x > max_val
        max_val = x

outputf("Max: %d\n", max_val)

# ── 7. Function with builtins ──
function stats(arr, n)
    outputf("Sum: %d\n", sum(arr))
    outputf("Min: %d\n", min(arr))
    outputf("Max: %d\n", max(arr))
    outputf("Len: %d\n", len(arr))

data = [100, 200, 300, 400, 500]
stats(data, 5)
