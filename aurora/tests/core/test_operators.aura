# ════════════════════════════════════════════════════════════
# Aurora Operator Test — All Operators
# ════════════════════════════════════════════════════════════

output("=== Arithmetic Operators ===")

# ── Addition ──
outputf("10 + 5 = %d\n", 10 + 5)
outputf("0 + 0 = %d\n", 0 + 0)
outputf("-5 + 5 = %d\n", -5 + 5)

# ── Subtraction ──
outputf("10 - 3 = %d\n", 10 - 3)
outputf("0 - 5 = %d\n", 0 - 5)
outputf("100 - 100 = %d\n", 100 - 100)

# ── Multiplication ──
outputf("4 * 5 = %d\n", 4 * 5)
outputf("0 * 99 = %d\n", 0 * 99)
outputf("7 * 7 = %d\n", 7 * 7)

# ── Division ──
outputf("20 / 4 = %d\n", 20 / 4)
outputf("100 / 10 = %d\n", 100 / 10)
outputf("7 / 2 = %d\n", 7 / 2)

# ── Modulo ──
outputf("10 %% 3 = %d\n", 10 % 3)
outputf("15 %% 5 = %d\n", 15 % 5)
outputf("7 %% 2 = %d\n", 7 % 2)

# ── Power ──
outputf("2 ** 10 = %d\n", 2 ** 10)
outputf("3 ** 3 = %d\n", 3 ** 3)
outputf("5 ** 0 = %d\n", 5 ** 0)

# ── Integer Division ──
outputf("10 // 3 = %d\n", 10 // 3)
outputf("20 // 4 = %d\n", 20 // 4)

output("")
output("=== Comparison Operators ===")

# ── Equal ──
outputf("5 == 5 = %b\n", 5 == 5)
outputf("5 == 3 = %b\n", 5 == 3)

# ── Not Equal ──
outputf("5 != 3 = %b\n", 5 != 3)
outputf("5 != 5 = %b\n", 5 != 5)

# ── Less Than ──
outputf("3 < 5 = %b\n", 3 < 5)
outputf("5 < 3 = %b\n", 5 < 3)
outputf("5 < 5 = %b\n", 5 < 5)

# ── Greater Than ──
outputf("5 > 3 = %b\n", 5 > 3)
outputf("3 > 5 = %b\n", 3 > 5)
outputf("5 > 5 = %b\n", 5 > 5)

# ── Less or Equal ──
outputf("3 <= 5 = %b\n", 3 <= 5)
outputf("5 <= 5 = %b\n", 5 <= 5)
outputf("5 <= 3 = %b\n", 5 <= 3)

# ── Greater or Equal ──
outputf("5 >= 3 = %b\n", 5 >= 3)
outputf("5 >= 5 = %b\n", 5 >= 5)
outputf("3 >= 5 = %b\n", 3 >= 5)

output("")
output("=== Bitwise Operators ===")

# ── AND ──
outputf("12 & 10 = %d\n", 12 & 10)
outputf("255 & 15 = %d\n", 255 & 15)

# ── OR ──
outputf("12 | 10 = %d\n", 12 | 10)
outputf("1 | 2 = %d\n", 1 | 2)

# ── XOR ──
outputf("12 ^ 10 = %d\n", 12 ^ 10)
outputf("6 xor 3 = %d\n", 6 xor 3)

output("")
output("=== Logical Operators ===")

# ── AND ──
outputf("1 and 1 = %b\n", 1 and 1)
outputf("1 and 0 = %b\n", 1 and 0)
outputf("0 and 1 = %b\n", 0 and 1)
outputf("0 and 0 = %b\n", 0 and 0)

# ── OR ──
outputf("1 or 1 = %b\n", 1 or 1)
outputf("1 or 0 = %b\n", 1 or 0)
outputf("0 or 1 = %b\n", 0 or 1)
outputf("0 or 0 = %b\n", 0 or 0)

# ── NOT ──
outputf("not 0 = %b\n", not 0)
outputf("not 1 = %b\n", not 1)
outputf("not 42 = %b\n", not 42)

output("")
output("=== Unary Operators ===")

# ── Negation ──
outputf("-5 = %d\n", -5)
outputf("-(-5) = %d\n", -(-5))
outputf("-0 = %d\n", -0)
outputf("-(10 + 5) = %d\n", -(10 + 5))

output("")
output("=== Compound Assignment ===")

# ── += ──
x = 10
x += 5
outputf("x = 10; x += 5 → %d\n", x)

# ── -= ──
x = 20
x -= 8
outputf("x = 20; x -= 8 → %d\n", x)

# ── *= ──
x = 6
x *= 7
outputf("x = 6; x *= 7 → %d\n", x)

# ── /= ──
x = 100
x /= 4
outputf("x = 100; x /= 4 → %d\n", x)

output("")
output("=== Operator Precedence ===")

# ── Precedence test: * before + ──
outputf("2 + 3 * 4 = %d\n", 2 + 3 * 4)
outputf("(2 + 3) * 4 = %d\n", (2 + 3) * 4)

# ── Precedence test: ** before * ──
outputf("2 * 3 ** 2 = %d\n", 2 * 3 ** 2)

# ── Precedence test: comparison after arithmetic ──
outputf("2 + 3 > 4 = %b\n", 2 + 3 > 4)
outputf("10 - 5 == 5 = %b\n", 10 - 5 == 5)

output("")
output("=== Mixed Expressions ===")

a = 10
b = 20
c = 30
outputf("a + b + c = %d\n", a + b + c)
outputf("a * b + c = %d\n", a * b + c)
outputf("a + b * c = %d\n", a + b * c)
outputf("(a + b) * c = %d\n", (a + b) * c)

# ── Chained comparisons ──
outputf("1 < 2 and 2 < 3 = %b\n", 1 < 2 and 2 < 3)
outputf("1 < 2 and 3 < 2 = %b\n", 1 < 2 and 3 < 2)
outputf("1 == 1 or 2 == 3 = %b\n", 1 == 1 or 2 == 3)
outputf("1 == 2 or 2 == 3 = %b\n", 1 == 2 or 2 == 3)
