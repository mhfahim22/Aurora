class Person
    public name = "unknown"
    private age = 0
    
    function get_name()
        return self.name
    
    function set_age(a)
        self.age = a
    
    function get_age()
        return self.age

p = Person("Alice")
output(p.get_name())
p.set_age(42)
output(p.get_age())
output("DONE")
