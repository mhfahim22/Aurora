# ── Interface Declaration ──
interface Drawable
    function draw()
    function resize(w, h)

# ── Class implementing interface ──
class Square implements Drawable
    size = 10
    function draw()
        output(self.size)
    function resize(w, h)
        self.size = w

s = Square(5)
s.draw()
s.resize(20, 20)
s.draw()

# ── Interface with extends ──
interface Shape extends Drawable
    function area()

output(333)
