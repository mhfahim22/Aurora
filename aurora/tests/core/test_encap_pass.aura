class Person
    public name = "unknown"
    private age = 0
    protected nickname = "none"
    
    function set_age(a)
        self.age = a
    
    function get_age()
        return self.age

p = Person("Alice")
output("Name: " + p.name)
p.set_age(25)
output("Age: " + p.get_age())
output("DONE")
