# ══════════════════════════════════
# Aurora Language — Full Feature Test
# ══════════════════════════════════

# ── 1. Variables & Types ──
x = 42
f = 3.14
s = "Aurora"
output(x)       # 42
output(f)       # 3.140000
output(s)       # Aurora

# ── 2. Arithmetic ──
output(x + 8)       # 50
output(x - 2)       # 40
output(x * 2)       # 84
output(x / 5)       # 8
output(x % 5)       # 2
output(2 ** 10)     # 1024
output(f + 1.0)     # 4.140000
output(f * 2.0)     # 6.280000

# ── 3. String Concatenation ──
a = "Hello"
b = " World"
output(a + b)           # Hello World
output("Foo" + "Bar")   # FooBar

# ── 4. Comparison ──
output(10 > 5)      # 1
output(10 < 5)      # 0
output(10 == 10)    # 1
output(10 != 5)     # 1

# ── 5. If / Elseif / Else ──
n = 75
if n > 100
    output("big")
elseif n > 50
    output("medium")    # medium
else
    output("small")

# ── 6. While Loop ──
i = 0
while i < 3
    output(i)       # 0 1 2
    i = i + 1

# ── 7. For Loop ──
for j in 4
    output(j)       # 0 1 2 3

# ── 8. Functions ──
function add(a, b)
    return a + b

function multiply(a, b)
    return a * b

output(add(10, 20))         # 30
output(multiply(6, 7))      # 42

# ── 9. Recursion ──
function factorial(n)
    if n <= 1
        return 1
    return n * factorial(n - 1)

output(factorial(5))    # 120
output(factorial(10))   # 3628800

# ── 10. Array ──
arr = [1, 2.5, "hello", 42]
output(arr)         # [1, 2.50, "hello", 42]
output(arr[0])      # 1
output(arr[2])      # hello
arr[0] = 99
output(arr[0])      # 99

# ── 11. Array Sum ──
nums = [10, 20, 30, 40, 50]
total = 0
for k in 5
    total = total + nums[k]
output(total)       # 150

# ── 12. Nested Function ──
function max(a, b)
    if a > b
        return a
    return b

output(max(100, 200))   # 200
output(max(999, 1))     # 999

# ── 13. String in Function ──
function greet(name)
    return 0

output("Hello " + "Aurora!")    # Hello Aurora!

# ── 14. Boolean Logic ──
output(1 and 1)     # 1
output(1 and 0)     # 0
output(0 or 1)      # 1
output(0 or 0)      # 0

# ── 15. XOR ──
output(6 ^ 3)       # 5
output(6 xor 3)     # 5

# ── 16. Scope Cleanup / Early Return ──
if 1
    scoped = [7, 8, 9]
    output(scoped[1])     # 8

function first_item(flag)
    temp = [11, 22, 33]
    if flag > 0
        return temp[0]
    return temp[2]

output(first_item(1))     # 11
output(first_item(0))     # 33

function stop_after_return()
    return 123
    output(999)

output(stop_after_return())    # 123
