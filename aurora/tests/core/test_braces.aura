# Test inline function bodies

function f1() return 1
output(f1())

function f2() 42
output(f2())

function f3(a, b) return a + b
output(f3(10, 20))

function f4() {
    return 99
}
output(f4())

function f5() { return 55 }
output(f5())

# Old syntax still works
function add(x, y)
    return x + y

output(add(5, 7))
