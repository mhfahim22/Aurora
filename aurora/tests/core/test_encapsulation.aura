class Person
    public name = "unknown"
    private age = 0
    protected nickname = "none"
    
    function set_age(a)
        self.age = a
    
    function get_age()
        return self.age
    
    function set_nickname(n)
        self.nickname = n
    
    function get_nickname()
        return self.nickname

class Employee extends Person
    function show_info()
        # Can access protected nickname from parent
        output("Nickname: " + self.nickname)
        
        # Can NOT access private age directly - use getter
        output("Age via getter: " + self.get_age())

p = Person("Alice")
output("Public name: " + p.name)

# Can't access private field directly - will fail at compile time
# Uncomment to test:
# p.age = 25

# Use getter/setter instead
p.set_age(25)
output("Age: " + p.get_age())

p.set_nickname("Ali")
output("Nickname: " + p.get_nickname())

e = Employee("Bob", 30, "Bobby")
e.show_info()

output("DONE")
