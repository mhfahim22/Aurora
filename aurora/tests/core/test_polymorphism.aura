interface Greeter
    function greet()
    function farewell()

class EnglishSpeaker implements Greeter
    function greet()
        output("Hello!")
    function farewell()
        output("Goodbye!")

class FrenchSpeaker implements Greeter
    function greet()
        output("Bonjour!")
    function farewell()
        output("Au revoir!")

# Test basic interface implementation
e = EnglishSpeaker()
e.greet()
e.farewell()

f = FrenchSpeaker()
f.greet()
f.farewell()

output("DONE")
