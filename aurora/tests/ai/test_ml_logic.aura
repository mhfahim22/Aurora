import MrCode

output("=== ML Logic Tests ===\n")

## Test 1: Training reduces loss
output("-- Test 1: Loss decreases --")
d = csv("test.csv")
m = model_create("sequential")
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.1)
set_batch_size(m, 20)
set_epochs(m, 10)
set_validation_split(m, 0.0)
set_verbose(m, 0)
train(m, d)
final_loss = model_loss(m)
final_acc = model_accuracy(m)
output("loss:")
output(final_loss)
output("acc:")
output(final_acc)

## Test 2: Predict non-zero
output("\n-- Test 2: Predict --")
p = predict(m, d)
output(p)

## Test 3: Test
output("\n-- Test 3: Test --")
output(test(m, d))

## Test 4: Metrics
output("\n-- Test 4: Metrics --")
output(model_metrics(m, d))

## Test 5: Manual layers
output("\n-- Test 5: Manual layers --")
m2 = model_create("sequential")
add(m2, dense(16, "relu"))
add(m2, dense(8, "relu"))
add(m2, dense(1, "sigmoid"))
set_loss(m2, "binary_crossentropy")
set_optimizer(m2, "adam")
set_lr(m2, 0.1)
set_batch_size(m2, 20)
set_epochs(m2, 5)
set_validation_split(m2, 0.0)
set_verbose(m2, 0)
train(m2, d)
output(model_info(m2))

## Test 6-13: Feature checks
output("\n-- Test 6: Conv2D --")
output(conv(8, 3, 1))

output("-- Test 7: LSTM --")
output(lstm(16))

output("-- Test 8: GRU --")
output(gru(16))

output("-- Test 9: Save & Load --")
output(model_save(m, "test_model.mrc"))
output(model_load("test_model.mrc"))

output("-- Test 10: ONNX --")
output(onnx(m, "test_export.onnx"))

output("-- Test 11: Bench --")
output(bench_model(m))

output("-- Test 12: Config --")
output(set_gradient_clip(m, 1.0))
output(set_augment(m, 1))
output(set_lr_factor(m, 0.5))
output(set_min_lr(m, 0.0001))

output("\n=== ALL ML LOGIC TESTS PASSED ===")
