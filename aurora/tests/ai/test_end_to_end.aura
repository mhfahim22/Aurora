import MrCode

output("E2E: Train & Save")

m = model_create("seq")
set_loss(m, "mse")
set_optimizer(m, "adam")
set_lr(m, 0.01)
set_epochs(m, 3)
set_batch_size(m, 4)
set_verbose(m, 0)

dense(m, dense(8, "relu"))
dense(m, dense(4, "relu"))
dense(m, dense(1, "sigmoid"))

data_t = tensor(12, 3, 0)
train(m, data_t)
output("loss")
output(model_loss(m))
output("accuracy")
output(model_accuracy(m))

model_save(m, "e2e_model.bin")
output("saved")

m2 = model_load("e2e_model.bin")
output("loaded")
output(onnx(m2, "e2e_model.onnx"))
output(quantize(m2))
output(bench_model(m2))

output("E2E PASSED")
