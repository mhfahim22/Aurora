import MrCode
output("=== MrCode Enterprise Test ===")
output("-- csv --")
d = csv("test.csv")
output(d)
output("-- model_create --")
m = model_create("sequential")
output(m)
output("-- config --")
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.01)
set_batch_size(m, 20)
set_epochs(m, 2)
set_validation_split(m, 0.0)
set_verbose(m, 0)
set_early_stop(m, 5)
set_checkpoint_interval(m, 0)
output("config ok")
output("-- train --")
r = train(m, d)
output(r)
output("-- model_info --")
output(model_info(m))
output("-- model_size --")
output(model_size(m))
output("-- model_accuracy --")
output(model_accuracy(m))
output("-- model_loss --")
output(model_loss(m))
output("-- bench_model --")
output(bench_model(m))
output("-- test --")
output(test(m, d))
output("-- predict --")
output(predict(m, d))
output("-- shuffle --")
output(shuffle(d))
output("-- clean --")
output(clean(d))
output("-- normalize --")
output(normalize(d))
output("-- standard --")
output(standard(d))
output("-- split_data --")
output(split_data(d, 0.8))
output("=== DONE ===")
