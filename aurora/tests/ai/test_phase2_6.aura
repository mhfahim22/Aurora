import MrCode

output("=== Phase 2-6 Integration Test ===\n")

## Test MHA with proper backward (training works)
output("-- Test: MHA Backward --")
m = model_create("sequential")
add(m, dense(4, "relu"))
add(m, mha(2))
add(m, dense(1, "sigmoid"))
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.1)
set_batch_size(m, 20)
set_epochs(m, 3)
set_validation_split(m, 0.0)
set_verbose(m, 0)
d = csv("test.csv")
train(m, d)
output("mha backward:")
output(model_loss(m))
output(model_accuracy(m))

## Test SiLU + GELU activations
output("\n-- Test: SiLU + GELU --")
m2 = model_create("sequential")
add(m2, dense(8, "silu"))
add(m2, dense(4, "gelu"))
add(m2, dense(1, "sigmoid"))
set_loss(m2, "binary_crossentropy")
set_optimizer(m2, "adam")
set_lr(m2, 0.1)
set_batch_size(m2, 20)
set_epochs(m2, 3)
set_validation_split(m2, 0.0)
set_verbose(m2, 0)
train(m2, d)
output("silu+gelu:")
output(model_loss(m2))
output(model_accuracy(m2))

## Test MoE layer
output("\n-- Test: MoE --")
m3 = model_create("sequential")
add(m3, moe(4, 8))
add(m3, dense(1, "sigmoid"))
set_loss(m3, "binary_crossentropy")
set_optimizer(m3, "adam")
set_lr(m3, 0.1)
set_batch_size(m3, 20)
set_epochs(m3, 3)
set_validation_split(m3, 0.0)
set_verbose(m3, 0)
train(m3, d)
output("moe:")
output(model_loss(m3))
output(model_accuracy(m3))

## Test RoPE layer
output("\n-- Test: RoPE --")
m4 = model_create("sequential")
add(m4, embedding(10, 8))
add(m4, rope())
add(m4, dense(8, "relu"))
add(m4, dense(4, "linear"))
add(m4, unembed())
output(model_info(m4))
output(generate_tokens(m4, 1, 6))

## Test Quantization
output("\n-- Test: Quantize --")
output(quantize(m))

output("\n=== ALL PHASES 2-6 TESTS PASSED ===")
