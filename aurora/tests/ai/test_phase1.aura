import MrCode

output("=== Phase 1 Features Test ===\n")

## Test RoPE layer
m = model_create("sequential")
add(m, embedding(10, 4))
add(m, rope())
add(m, dense(8, "relu"))
add(m, dense(4, "linear"))
add(m, unembed())
output(model_info(m))
output(generate_tokens(m, 1, 5))

## Test SiLU activation
output("\n-- SiLU --")
m2 = model_create("sequential")
add(m2, dense(8, "silu"))
add(m2, dense(1, "sigmoid"))
set_loss(m2, "binary_crossentropy")
set_optimizer(m2, "adam")
set_lr(m2, 0.1)
set_batch_size(m2, 20)
set_epochs(m2, 2)
set_validation_split(m2, 0.0)
set_verbose(m2, 0)
d = csv("test.csv")
train(m2, d)
output("silu model trained")

## Test GELU activation
output("\n-- GELU --")
m3 = model_create("sequential")
add(m3, dense(8, "gelu"))
add(m3, dense(1, "sigmoid"))
set_loss(m3, "binary_crossentropy")
set_optimizer(m3, "adam")
set_lr(m3, 0.1)
set_batch_size(m3, 20)
set_epochs(m3, 2)
set_validation_split(m3, 0.0)
set_verbose(m3, 0)
train(m3, d)
output("gelu model trained")

output("\n=== PHASE 1 DONE ===")
