import MrCode

d = csv("test.csv")
m = model_create("sequential")
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.01)
set_batch_size(m, 20)
set_epochs(m, 5)
set_validation_split(m, 0.2)
set_verbose(m, 0)

train(m, d)

output("-- test --")
tr = test(m, d)
output(tr)

output("-- predict --")
pr = predict(m, d)
output(pr)

output("-- predict output tensor ndim --")
output(pr)

output("-- model_metrics --")
mm = model_metrics(m, d)
output(mm)

output("-- bench_model --")
bm = bench_model(m)
output(bm)
