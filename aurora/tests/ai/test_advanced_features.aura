import MrCode

output("ADV: advanced features verification")

m = model_create("seq")
set_loss(m, "cross_entropy")
set_optimizer(m, "adam")
set_lr(m, 0.001)
set_batch_size(m, 2)
set_epochs(m, 2)
set_verbose(m, 0)

add(m, embedding(100, 64))
add(m, pos_encoding())
add(m, mha(2))
add(m, layernorm())
add(m, unembed())
output("model built")

data_t = tensor(4, 4, 0)
train(m, data_t)
output("loss")
output(model_loss(m))

model_save(m, "adv_model.bin")
output("saved")
m2 = model_load("adv_model.bin")
output("loaded")

output(onnx(m2, "adv_model.onnx"))
output(quantize(m2))
output(quantize_kv_cache_builtin(m2))
output(quantize_groupwise_builtin(m2, 32))
output(set_dtype(m2, "f16"))

m3 = model_copy(m2)
output("copy ok")

output(temperature(0.7))
output(top_p(0.9))
output(max_tokens(100))

output(loader_load_nanogpt("nonexistent.bin"))
output(loader_get_config(0))

output(distributed_init())
output(distributed_rank())
output(distributed_size())

output("ADV: ALL VERIFIED")
