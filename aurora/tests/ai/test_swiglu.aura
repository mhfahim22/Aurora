import MrCode

output("=== SwiGLU FFN Test ===\n")

m = model_create("sequential")
add(m, dense(4, "relu"))
add(m, swiglu_ffn(8, 1))
set_loss(m, "mse")
set_optimizer(m, "adam")
set_lr(m, 0.01)
set_batch_size(m, 4)
set_epochs(m, 3)
set_verbose(m, 1)

output("model created\n")

data = csv("test_data.csv")
output("data loaded. training...\n")
r = train(m, data)
output("train result: " + str(r) + "\n")

output("=== SWIGLU DONE ===\n")
