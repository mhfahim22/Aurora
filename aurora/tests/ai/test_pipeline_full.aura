import MrCode

output("PIPELINE: full pipeline test")

m = model_create("seq")
set_loss(m, "mse")
set_optimizer(m, "adam")
set_lr(m, 0.01)
set_epochs(m, 3)
set_batch_size(m, 4)
set_verbose(m, 0)

dense(m, dense(8, "relu"))
dense(m, dense(4, "relu"))
dense(m, dense(1, "sigmoid"))

data_t = tensor(12, 3, 0)
train(m, data_t)
output("loss")
output(model_loss(m))

model_save(m, "pipe_model.bin")
m2 = model_load("pipe_model.bin")
m3 = model_copy(m2)
test_in = tensor(1, 3, 0)
predict(m3, test_in)
output("predicted ok")

output(onnx(m3, "pipe_model.onnx"))
output(quantize(m3))
output(bench_model(m3))
output(temperature(0.8))
output(top_p(0.9))
output(max_tokens(50))

cs = chat_new()
chat_system(cs, "You are a helpful assistant.")
chat_reset(cs)
output("chat ok")

output(loader_load_nanogpt("nonexistent.bin"))
output(loader_get_config(0))

output("PIPELINE PASSED")
