import MrCode

output("LORA: verification")

m = model_create("seq")
set_loss(m, "mse")
set_optimizer(m, "adam")
set_lr(m, 0.01)
set_epochs(m, 3)
set_batch_size(m, 2)
set_verbose(m, 0)

dense(m, dense(16, "relu"))
dense(m, dense(8, "relu"))
dense(m, dense(1, "sigmoid"))

output("model built")
output(model_info(m))

output("casting to low precision (F16)...")
output(model_cast_to_lowp(m, 2))
output("sync weights to master...")
output(model_sync_weights_to_master(m))
output("adding LoRA (rank=4, alpha=1.0, dropout=0.1)...")
output(model_add_lora(m, 4, 1.0, 0.1))
output("sync weights from master...")
output(model_sync_weights_from_master(m))

data_t = tensor(8, 4, 0)
train(m, data_t)
output("loss")
output(model_loss(m))
output("accuracy")
output(model_accuracy(m))

model_save(m, "lora_model.bin")
output("saved")
m2 = model_load("lora_model.bin")
output("loaded")
output(model_info(m2))

output(onnx(m2, "lora_model.onnx"))
output(quantize(m2))

output(temperature(0.8))
output(top_p(0.9))
output(max_tokens(50))

output("LORA: ALL VERIFIED")
