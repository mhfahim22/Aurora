import MrCode
output("-- MHA train (1 batch) test --\n")
m = model_create("sequential")
add(m, dense(4, "relu"))
add(m, mha(2))
add(m, dense(1, "sigmoid"))
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.1)
set_batch_size(m, 20)
set_epochs(m, 1)
set_validation_split(m, 0.0)
set_verbose(m, 0)
d = csv("test.csv")
output("fit...\n")
r = fit(m, d, d)
output("loss:\n")
output(r)
