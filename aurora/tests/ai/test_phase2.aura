import MrCode

output("=== Phase 2: FlashAttention + MHA Backward Test ===\n")

## ── Test 1: Generation with KV cache ──
output("--- Test 1: Generation ---\n")
m = model_create("sequential")
add(m, embedding(100, 64))
add(m, mha(8))
add(m, dense(64, "relu"))
add(m, unembed())
set_loss(m, "categorical_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.01)
output("generate: " + generate_tokens(m, 1, 5) + "\n")

## ── Test 2: Training with MHA (FlashAttention backward) ──
output("\n--- Test 2: Training ---\n")
m2 = model_create("sequential")
add(m2, dense(4, "relu"))
add(m2, mha(4))
add(m2, dense(1, "linear"))
set_loss(m2, "mse")
set_optimizer(m2, "adam")
set_lr(m2, 0.01)
set_batch_size(m2, 4)
set_epochs(m2, 2)
set_verbose(m2, 1)

data = csv("test_data.csv")
output("data loaded. training...\n")
train(m2, data)

output("\n=== PHASE 2 DONE ===\n")
