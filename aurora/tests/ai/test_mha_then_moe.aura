import MrCode

## Test 1: MHA model
output("-- MHA --\n")
m = model_create("sequential")
add(m, dense(4, "relu"))
add(m, mha(2))
add(m, dense(1, "sigmoid"))
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.1)
set_batch_size(m, 20)
set_epochs(m, 3)
set_validation_split(m, 0.0)
set_verbose(m, 0)
d = csv("test.csv")
train(m, d)
output("mha done\n")

## Test 2: MoE model  
output("-- MoE --\n")
m2 = model_create("sequential")
add(m2, moe(4, 8))
add(m2, dense(1, "sigmoid"))
set_loss(m2, "binary_crossentropy")
set_optimizer(m2, "adam")
set_lr(m2, 0.1)
set_batch_size(m2, 20)
set_epochs(m2, 3)
set_validation_split(m2, 0.0)
set_verbose(m2, 0)
train(m2, d)
output("moe done\n")

