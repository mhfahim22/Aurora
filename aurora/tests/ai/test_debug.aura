import MrCode

output("MHA training test\n")

m = model_create("sequential")
add(m, dense(4, "relu"))
add(m, mha(4))
add(m, dense(1, "linear"))
set_loss(m, "mse")
set_optimizer(m, "adam")
set_lr(m, 0.001)
set_epochs(m, 1)

data = csv("test_data.csv")
output("data loaded, rows=32, cols=5\n")

## Manual test: call train
output("calling train...\n")
r = train(m, data)
output("result: " + str(r) + "\n")
