import MrCode

output("Simple MHA test\n")

m = model_create("sequential")
add(m, embedding(100, 16))
add(m, mha(4))
add(m, unembed())
set_loss(m, "categorical_crossentropy")
set_optimizer(m, "adam")

output("generating...\n")
t = generate_tokens(m, 1, 10)
output("tokens: " + t + "\n")

output("\ntraining...\n")
data = csv("test_data.csv")
output("data ok\n")

## This model has wrong dimensions for training, but let's see if forward works
r = train(m, data)
output("result: " + str(r) + "\n")
