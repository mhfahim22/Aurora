import MrCode

m = model_create("sequential")
add(m, moe(4, 8))
add(m, dense(1, "sigmoid"))
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.1)
set_batch_size(m, 20)
set_epochs(m, 2)
set_verbose(m, 0)
output("before train\n")
d = csv("test.csv")
output("data loaded, training...\n")
r = train(m, d)
output("train result: " + str(r) + "\n")
output("OK\n")

