import MrCode

m = model_create("sequential")
add(m, moe(4, 8))
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.1)
set_batch_size(m, 20)
set_epochs(m, 2)
set_validation_split(m, 0.0)
set_verbose(m, 0)
d = csv("test.csv")
train(m, d)
output(model_loss(m))
output(" === ALL PASSED ===\n")
