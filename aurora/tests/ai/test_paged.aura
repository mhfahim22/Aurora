import MrCode

output("=== Phase 5: PagedAttention + KV Cache Test ===\n")

## Build a transformer model
m = model_create("sequential")
add(m, embedding(100, 32))
add(m, mha(4))
add(m, dense(32, "relu"))
add(m, unembed())
set_loss(m, "categorical_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.01)

output("model created: " + model_info(m))

## Test generation (uses KV cache internally now)
output("generating tokens: " + generate_tokens(m, 1, 10))

output("\n=== PHASE 5 DONE ===\n")