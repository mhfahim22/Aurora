import MrCode

output("start\n")
m = model_create("sequential")
output("created\n")
# Just add a dummy layer instead of moe
l = dense(8, "relu")
add(m, l)
output("dense added\n")
l2 = dense(1, "sigmoid")
add(m, l2)
output("dense2 added\n")
set_loss(m, "binary_crossentropy")
set_optimizer(m, "adam")
set_lr(m, 0.1)
set_batch_size(m, 20)
set_epochs(m, 1)
set_validation_split(m, 0.0)
set_verbose(m, 0)
output("settings done\n")
d = csv("test.csv")
output("csv loaded\n")
output("training...\n")
train(m, d)
output("done\n")
output(" === ALL PASSED ===\n")
