extern "native_kernel32" function GetTickCount() -> i64
extern "native_kernel32" function GetLastError() -> i32
extern "native_kernel32" function Beep(dwFreq: i32, dwDuration: i32) -> i32
extern "native_kernel32" function IsProcessorFeaturePresent(feature: i32) -> i32

function main():
    output("--- Native Bridge End-to-End Test ---")
    start = GetTickCount()
    if start == 0:
        output("FAIL: GetTickCount should not be 0")
        return 1
    output("PASS: GetTickCount() = " + str(start))

    err = GetLastError()
    output("PASS: GetLastError() = " + str(err))

    pf = IsProcessorFeaturePresent(0)
    output("PASS: IsProcessorFeaturePresent(0) = " + str(pf))

    end = GetTickCount()
    elapsed = end - start
    output("PASS: elapsed " + str(elapsed) + "ms")
    output("--- All Native Bridge Tests Passed ---")
    return 0
