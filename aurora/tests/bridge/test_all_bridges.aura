/* Combined end-to-end test for all available ecosystem bridges */
import "npm:moment"

extern "npm_moment" function moment_require() -> pointer
extern "npm_moment" function moment_call(mod: pointer, fn: cstring, args: pointer) -> pointer
extern "npm_moment" function moment_to_cstr(obj: pointer) -> pointer
extern "npm_moment" function moment_str(s: cstring) -> pointer
extern "npm_moment" function moment_free(handle: pointer)
extern "npm_moment" function moment_free_cstr(handle: pointer)

function main():
    output("--- All Bridges Combined End-to-End Test ---")
    passed = 0
    failed = 0

    mod = moment_require()
    if mod == 0:
        output("FAIL: moment_require() returned null")
        failed = failed + 1
    else:
        now = moment_call(mod, "now", 0)
        ts = moment_to_cstr(now)
        if ts != 0:
            output("PASS: moment.now() = " + str(ts))
            moment_free_cstr(ts)
            passed = passed + 1
        else:
            output("FAIL: moment.now() null")
            failed = failed + 1
        output("Result: " + str(passed) + " so far")
        moment_free(now)
        output("-")
        moment_free(mod)

    output("Total: " + str(passed) + " passed, " + str(failed) + " failed")
    if failed > 0:
        return 1
    output("--- All Bridge Tests Passed ---")
    return 0