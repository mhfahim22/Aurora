import "pypi:markdown"

extern "pypi_markdown" function markdown_import() -> pointer
extern "pypi_markdown" function markdown_call1(mod: pointer, fn: cstring, arg: pointer) -> pointer
extern "pypi_markdown" function markdown_str(s: cstring) -> pointer
extern "pypi_markdown" function markdown_free(handle: pointer)

function main():
    output("--- PyPI Bridge Test ---")
    mod = markdown_import()
    if mod == 0:
        output("FAIL: markdown_import() returned null")
        output("note: run 'voss bridge pypi markdown' first")
        return 1
    output("PASS: markdown_import() ok")

    md = markdown_str("# Hello\n\n**world**")
    result = markdown_call1(mod, "markdown", md)
    if result != 0:
        output("PASS: markdown() returned non-null")
    else:
        output("FAIL: markdown() returned null")
        markdown_free(md)
        markdown_free(mod)
        return 1

    markdown_free(result)
    markdown_free(md)
    markdown_free(mod)
    output("--- PyPI Bridge Test Completed ---")
    return 0
