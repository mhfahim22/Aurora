# Test: AI/ML Simplified Built-ins (plan.txt)
import MrCode
output("=== Data Loading ===")
output(csv("test.csv"))
output(image("test.png"))
output(text("test.txt"))
output(audio("test.wav"))
output(video("test.mp4"))

output("=== Data Processing ===")
arr = [1, 2, 3, 0, 5]
output(clean(arr))
output(shuffle(arr))
output(normalize(arr))
output(standard(arr))
output(remove_null(arr))

output("=== Model Management ===")
m = model_create("dense")
output(m)
output(model_load("model.bin"))
output(model_save(m, "model.bin"))
m2 = model_copy(m)
output(m2)

output("=== Training ===")
m2 = model_create("dense")
t = tensor(5, 2, 0)
output(train(m2, t))
output(retrain(m2))

output("=== Layers ===")
output(dense(128, "relu"))
output(conv(64, 3, 1))
output(lstm(256))
output(gru(128))
output(dropout(0.5))
output(batchnorm())
output(attention())
output(transformer())

output("=== Vision ===")
output(detect("img.jpg"))
output(classify_image("img.jpg"))
output(segment("img.jpg"))
output(face("img.jpg"))
output(ocr("img.jpg"))

output("=== NLP ===")
output(generate("hello"))
output(explain("code here"))
output(complete("once upon"))
t = tokens("hello world foo")
output(t)
output(summary("long text"))
output(sentiment("good"))
output(keywords("test text here"))
output(create_embed("text"))

output("=== Vector ===")
output(similar(arr, arr))
output(nearest(arr, 3))
output(index_create(arr))
output(retrieve(arr))
output(add_doc(arr))
output(remove_doc(1))

output("=== Agent ===")
output(agent())
output(train_agent(m))
output(reward(m, 1.0))

output("=== Device ===")
output(gpu())
output(gpu_mem())
output(device())

output("=== Model Info ===")
