output(audio_gen("prompt"))
output(video_gen("prompt"))
output(music_gen("prompt"))

output("=== Agent Ops ===")
output(ag_run("task"))
output(ag_memory())
output(ag_tools())
output(ag_stop())

output("=== Model Ops ===")
output(quantize(m))
output(compile(m))
output(onnx(m, "model.onnx"))
