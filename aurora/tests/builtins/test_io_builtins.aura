# ════════════════════════════════════════════════════════════
# Aurora I/O Built-in Functions Test
# ════════════════════════════════════════════════════════════

# ── outputln (print without newline) ──
outputln("Hello")
outputln(" ")
outputln("World")
outputN()

# ── outputN (just newline) ──
output("Line 1")
outputN()
output("Line 3")

# ── outputf (formatted output) ──
outputf("Name: %s, Age: %d\n", "Alice", 30)
outputf("Score: %d, Pass: %b\n", 95, 1)
outputf("Value: %d\n", 42)

# ── Combined usage ──
outputln("Loading")
for i in 3
    outputln(".")
outputN()
output("Done!")

# ── Array + I/O ──
arr = [10, 20, 30]
outputf("Array: [%d, %d, %d]\n", arr[0], arr[1], arr[2])
outputf("Sum: %d\n", sum(arr))
outputf("Len: %d\n", len(arr))
