# ════════════════════════════════════════════════════════════
# Aurora All Built-in Functions Test
# ════════════════════════════════════════════════════════════

output("=== String Builtins ===")

# ── upper / lower ──
s = "Hello World"
output(upper(s))
output(lower(s))

# ── trim ──
t = "  spaced  "
output(trim(t))

# ── replace ──
r = replace("aabbcc", "bb", "dd")
output(str(r))

# ── split ──
parts = split("a,b,c", ",")
output(len(parts))

# ── has (string) ──
output(has("hello world", "world"))
output(has("hello world", "xyz"))

# ── starts / ends ──
output(starts("hello", "he"))
output(starts("hello", "xyz"))
output(ends("hello", "lo"))
output(ends("hello", "xy"))

# ── reverse (string) ──
output(str(reverse("abc")))

output("=== Math Builtins ===")

# ── abs ──
output(abs(-5))

# ── sqrt / floor / ceil / round ──
output(sqrt(9.0))
output(floor(3.7))
output(ceil(3.2))
output(round(3.5))

# ── pow ──
output(pow(2.0, 3.0))

# ── clamp ──
output(clamp(5.0, 0.0, 10.0))
output(clamp(-1.0, 0.0, 10.0))
output(clamp(15.0, 0.0, 10.0))

# ── rand ──
n = rand()
output(n >= 0)

output("=== Collection Builtins ===")

# ── push / pop ──
arr = [1, 2, 3]
push(arr, 4)
output(len(arr))
v = pop(arr)
output(v)
output(len(arr))

# ── insert / remove ──
arr2 = [10, 20, 30, 40]
insert(arr2, 1, 99)
output(len(arr2))
remove(arr2, 1)
output(len(arr2))

# ── clear ──
arr3 = [5, 6, 7]
clear(arr3)
output(len(arr3))

# ── sort ──
arr4 = [3, 1, 4, 1, 5, 9, 2, 6]
sort(arr4)
output(arr4[0])
output(arr4[1])
output(arr4[2])

# ── unique ──
u = unique([1, 1, 2, 2, 3])
output(len(u))

# ── reverse (array) ──
arr5 = [1, 2, 3]
reverse(arr5)
output(arr5[0])
output(arr5[1])

# ── has (array) ──
output(has([1, 2, 3], 2))
output(has([1, 2, 3], 9))

output("=== Conversion Builtins ===")

# ── str, int, float, bool ──
output(str(42))
output(str(3.14))
output(int(3.99))
output(float(7) > 6.0)
output(bool(0))
output(bool(1))

output("=== File Builtins ===")

# ── write / read / exists / append / delete ──
testfile = "test_temp.txt"
output(write(testfile, "hello"))
output(exists(testfile))
content = read(testfile)
output(content)

output(append(testfile, " world"))
content2 = read(testfile)
output(content2)

output(delete(testfile))
output(exists(testfile) == 0)

# ── copy / move ──
src = "test_copy_src.txt"
dst = "test_copy_dst.txt"
write(src, "copy test")
output(copy(src, dst))
output(exists(dst))
delete(src)
delete(dst)

src2 = "test_move_src.txt"
dst2 = "test_move_dst.txt"
write(src2, "move test")
output(move(src2, dst2))
output(exists(dst2))
delete(dst2)

output("=== Path Builtins ===")

cdir = cwd()
output(len(cdir) > 0)

p = path("test_temp.txt")
output(len(p) > 0)

n = name("a/b/test.txt")
output(n)

e = ext("test.txt")
output(e)

output("=== Time Builtins ===")

output(now() > 0)
output(stamp() > 0)

output("=== OS Builtins ===")

output(len(os()) > 0)
output(cpu() > 0)
output(mem() > 0)
hv = env("PATH")
output(len(hv) > 0)

output("=== Error Builtins ===")

e = error("something went wrong")
output(len(e) > 0)

output("ALL DONE")
