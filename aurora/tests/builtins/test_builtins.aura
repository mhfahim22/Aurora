# ════════════════════════════════════════════════════════════
# Aurora Built-in Functions Test
# ════════════════════════════════════════════════════════════

# ── len() ──
arr = [10, 20, 30, 40, 50]
output(len(arr))

# ── sum() ──
output(sum(arr))

# ── min() / max() ──
output(min(arr))
output(max(arr))

# ── range() verified via len/sum/max ──
r1 = range(5)
output(len(r1))

r2 = range(3, 8)
output(len(r2))

# ── Combined ──
output(len(range(10)))
output(sum(range(5)))
output(max(range(10)))
output(min(range(3, 7)))

# ── Factorial (without range in for loop) ──
function factorial(n)
    result = 1
    i = 1
    while i <= n
        result = result * i
        i = i + 1
    return result

output(factorial(5))
output(factorial(10))
