## Test: database full + ORM (joins, group_by, having)
import libc:database
import libc:orm

function main()
    db = db_connect("postgresql://localhost/testdb")
    if map_has(db, "driver")
        output("connected")
    end

    ## ORM test — select with joins
    users = table_new(db, "users")
    q = query_select(users, ["users.id", "users.name", "posts.title"])
    q = query_inner_join(q, "posts", "users.id = posts.user_id")
    q = query_left_join(q, "comments", "posts.id = comments.post_id")
    q = query_where(q, "users.age > ?", [18])
    q = query_and_where(q, "users.active = ?", [1])
    q = query_group_by(q, "users.id")
    q = query_having(q, "count(posts.id) > 5")
    q = query_order_desc(q, "users.name")
    q = query_limit(q, 10)
    q = query_offset(q, 0)
    rows = query_execute(q)

    ## CRUD
    rc = query_insert(db, "users", ["name", "age"], ["Alice", 30])
    rc = query_update(db, "users", ["name"], ["Bob"], "id = ?")
    rc = query_delete(db, "users", "id = ?", [42])

    db_close(db)
end
