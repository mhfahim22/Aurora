# 1 Billion Ops — 8 non-linear chains (no SCEV elimination possible)
a = 7
b = 11
c = 13
d = 17
e = 19
f = 23
g = 29
h = 31
i = 0
while i < 125000000
    a = a + (a ^ i)
    b = b + (b ^ i)
    c = c + (c ^ i)
    d = d + (d ^ i)
    e = e + (e ^ i)
    f = f + (f ^ i)
    g = g + (g ^ i)
    h = h + (h ^ i)
    i = i + 1
r = a ^ b ^ c ^ d ^ e ^ f ^ g ^ h
output(r)
