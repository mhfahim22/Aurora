# ═══════════════════════════════════════
# Aurora Language — Full Power Benchmark
# ═══════════════════════════════════════

# ─── Part 1: Prime Counting ───
function is_prime(n)
    if n < 2
        return 0
    if n < 4
        return 1
    if n % 2 == 0
        return 0
    i = 3
    while i * i <= n
        if n % i == 0
            return 0
        i = i + 2
    return 1

function count_primes(limit)
    count = 0
    i = 2
    while i <= limit
        count = count + is_prime(i)
        i = i + 1
    return count

# ─── Part 2: Recursive Fibonacci ───
function fib(n)
    if n < 2
        return n
    return fib(n - 1) + fib(n - 2)

# ─── Part 3: Float Pi Approximation ───
function pi_leibniz(terms)
    pi = 0.0
    sign = 1.0
    i = 0
    while i < terms
        pi = pi + sign / (i * 2 + 1)
        sign = 0.0 - sign
        i = i + 1
    pi = pi * 4.0
    output(pi)

# ─── Part 4: Collatz Sum ───
function collatz_sum(limit)
    total = 0
    n = 1
    while n <= limit
        x = n
        while x > 1
            if x % 2 == 0
                x = x / 2
            else
                x = x * 3 + 1
            total = total + 1
        n = n + 1
    return total

# ─── Part 5: 1 Billion Ops (8 XOR chains, SCEV-proof) ───
function bench_1B_ops()
    a = 7
    b = 11
    c = 13
    d = 17
    e = 19
    f = 23
    g = 29
    h = 31
    i = 0
    while i < 125000000
        a = a ^ (i * 3 + 1)
        b = b ^ (i * 5 + 3)
        c = c ^ (i * 7 + 5)
        d = d ^ (i * 9 + 7)
        e = e ^ (i * 11 + 9)
        f = f ^ (i * 13 + 11)
        g = g ^ (i * 15 + 13)
        h = h ^ (i * 17 + 15)
        i = i + 1
    r = a ^ b ^ c ^ d ^ e ^ f ^ g ^ h
    return r

output("=== Aurora Power Benchmark ===")
output("--- Part 1 ---")
output(count_primes(50000))
output("--- Part 2 ---")
output(fib(30))
output("--- Part 3 ---")
pi_leibniz(10000000)
output("--- Part 4 ---")
output(collatz_sum(20000))
output("--- Part 5: 1B Ops ---")
output(bench_1B_ops())
output("=== DONE ===")
