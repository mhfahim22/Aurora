import MrCode

output("BENCH: matrix multiply speed test")

m = model_create("seq")
set_loss(m, "mse")
set_optimizer(m, "adam")
set_lr(m, 0.01)
set_epochs(m, 1)
set_batch_size(m, 1)
set_verbose(m, 0)

dense(m, dense(512, "relu"))
dense(m, dense(256, "relu"))
dense(m, dense(1, "sigmoid"))

data_t = tensor(4, 128, 0)
train(m, data_t)
output("trained")
output(model_loss(m))

output("device")
output(device())

output("BENCH DONE")
