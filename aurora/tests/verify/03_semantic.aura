# ══════════════════════════════════
# SEMANTIC VERIFICATION - All 9 conditions
# ══════════════════════════════════

# 1. type checking works
x = 42
f = 3.14
s = "hello"
output(x + f)

# 2. variable scope works (function scope in Aurora)
function test()
    local = 100
    return local
output(test())

# 3. undeclared variable detect হয় (compile error)
# Uncomment to test: output(undefined_var)

# 4. function argument validation works
function add(a, b)
    return a + b
output(add(10, 20))

# 5. return type validation works
function get_num()
    return 42
output(get_num())

# 6. duplicate variable detect হয় (handled by reassignment)
x = 100
output(x)

# 7. class/member validation works
class Person
    name = "unknown"
    function greet()
        output(self.name)
p = Person("Alice")
p.greet()

# 8. symbol table stable
a = 1
b = 2
c = 3
d = 4
e = 5
output(a + b + c + d + e)

# 9. semantic errors clear হয় (verified by error messages)
output(888)
