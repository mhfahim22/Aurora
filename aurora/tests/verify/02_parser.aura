# PARSER VERIFICATION

# 1. expressions parse
x = 1 + 2 * 3
y = (1 + 2) * 3
z = 10 / 2 - 3
output(x + y + z)

# 2. precedence correct
a = 2 + 3 * 4
b = 2 * 3 * 2
output(a + b)

# 3. loops parse
i = 0
while i < 5
    i = i + 1
for j in 3
    output(j)
output(i)

# 4. functions parse
function add(a, b)
    return a + b
function multiply(a, b)
    return a * b
output(add(10, 20))
output(multiply(6, 7))

# 5. arrays parse
arr = [1, 2, 3]
output(arr)

# 6. nested syntax works
function factorial(n)
    if n <= 1
        return 1
    return n * factorial(n - 1)
output(factorial(5))

# 7. expressions parse correctly
result = (10 + 20) * (30 - 15) / 3
output(result)

output(999)
