# ══════════════════════════════════
# OWNERSHIP VERIFICATION - All 10 conditions
# ══════════════════════════════════

# 1. move-after-use detect হয় (compile error)
# Uncomment to test: x = 42; y = move x; z = move x

# 2. borrow conflict detect হয় (compile error)
# Uncomment to test: x = 42; shared a = x; shared b = x

# 3. dangling reference prevent হয় (compile error)
# Uncomment to test: x = 42; free x; output(x)

# 4. shared refs work
x = 42
shared y = x
output(y)
output(x)

# 5. weak refs work
a = 42
weak b = a
output(b)

# 6. drop/free safe
c = 10
free c
# No crash

# 7. double free হয় না (compile error)
# Uncomment to test: d = 42; free d; free d

# 8. ownership transfer works
e = 100
f = move e
output(f)

# 9. lifetime analysis mostly correct
if 1
    temp = [1, 2, 3]
    output(temp[0])

# 10. runtime crash prevent হয়
output(777)
