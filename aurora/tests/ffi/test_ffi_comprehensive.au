extern struct DIR
extern "c" function fopen(path: cstring, mode: cstring) -> pointer
extern struct Point { x: int, y: int }
extern "math" function make_point(x: int, y: int) -> Point
extern union Data { i: int, f: float }
extern "scheduler" function set_timeout(ms: int, cb: callback() -> void) -> void
extern "scheduler" function map_values(data: cstring, cb: callback(int) -> int) -> cstring
extern struct Rect { x: int, y: int, w: int, h: int }
extern "physics" function check_collision(r1: Rect, r2: Rect) -> bool
extern "physics" function move_and_check(p: Point, dx: int, dy: int, on_collide: callback(Rect) -> void) -> Point

/* Calling convention + opaque + union all together */
extern "stdcall" function message_box(handle: pointer, text: cstring, caption: cstring, msg_type: int) -> int
