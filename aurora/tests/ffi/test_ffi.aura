## FFI demonstration module
## This module shows how to use Aurora's Foreign Function Interface
## to call C standard library functions.

## puts: Write a string to stdout
## @param s The string to print
## @returns Number of characters written
extern function puts(s: string) -> int

## getchar: Read a single character from stdin
## @returns The character read as an integer
extern function getchar() -> int

## abs: Compute absolute value of an integer
## @param x The input integer
## @returns The absolute value
extern function abs(x: int) -> int

## rand: Generate a pseudo-random number
## @returns A random integer between 0 and RAND_MAX
extern function rand() -> int

## main: Test all FFI functions
## Calls puts, rand, abs, and prints results
function main():
  output("--- FFI Test ---")
  ret = puts("Hello from FFI!")
  output(ret)
  r = rand()
  output(r)
  n = abs(-42)
  output(n)
  output("--- FFI DONE ---")
