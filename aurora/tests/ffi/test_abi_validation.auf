/* Basic ABI type validation */
extern function valid_fn(a: int, b: float, c: i8, d: pointer) -> bool
extern struct Coord { x: i32, y: i32, z: float }
extern union Value { as_int: i64, as_double: float }

extern function mixed_args(a: int, b: i32, c: i16, d: i8, e: float, f: double, g: string, h: bool, i: pointer, j: Coord) -> void

/* Calling convention syntax */
extern "stdcall" function win_api(a: int, b: pointer) -> int
extern "fastcall" function fast_api(x: int, y: int) -> int
extern "stdcall" "kernel32" function beep(freq: int, dur: int) -> bool
extern "c" function cdecl_fn(x: float) -> float

/* Opaque struct */
extern struct OpaqueHandle

/* Union with all accessible fields */
extern union IntOrFloat { as_int: i64, as_float: float }
