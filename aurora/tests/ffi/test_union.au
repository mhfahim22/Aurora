extern union Data { i: int, f: float, b: i8 }
extern union Variant { as_int: i64, as_float: float, as_ptr: pointer }
extern union IPAddress { as_i32: i32, as_bytes: pointer }

extern "sockets" function parse_address(addr: cstring) -> IPAddress
extern "sockets" function address_to_int(addr: IPAddress) -> i64

/* Verify all union fields are accessible */
extern union RGB { as_i32: i32, as_bytes: pointer, r: i8, g: i8, b: i8 }
extern "sockets" function rgb_to_int(r: i8, g: i8, b: i8) -> i32
