extern struct FILE
extern struct DIR
extern struct sqlite3
extern struct pthread_t

/* Opaque types should compile to [1 x i8] instead of zero-size struct */
extern struct HANDLE
extern struct HWND__
extern struct HINSTANCE__

extern "c" function fopen(path: cstring, mode: cstring) -> pointer
extern "c" function fclose(fp: pointer) -> i64
extern "c" function fread(buf: pointer, size: i64, count: i64, fp: pointer) -> i64
extern "c" function opendir(name: cstring) -> pointer
extern "c" function closedir(dirp: pointer) -> i64
