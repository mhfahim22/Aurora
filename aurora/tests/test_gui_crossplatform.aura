/* Phase 3 — Cross-platform GUI Test */

/* ── GUI function declarations ── */
extern function aurora_gui_window_new(title: string, w: int, h: int) -> int
extern function aurora_gui_window_set_title(win: int, title: string)
extern function aurora_gui_window_resize(win: int, w: int, h: int)
extern function aurora_gui_window_show(win: int)
extern function aurora_gui_window_hide(win: int)
extern function aurora_gui_window_destroy(win: int)
extern function aurora_gui_button_new(parent: int, text: string, x: int, y: int, w: int, h: int) -> int
extern function aurora_gui_button_set_text(btn: int, text: string)
extern function aurora_gui_label_new(parent: int, text: string, x: int, y: int, w: int, h: int) -> int
extern function aurora_gui_label_set_text(lbl: int, text: string)
extern function aurora_gui_textbox_new(parent: int, x: int, y: int, w: int, h: int) -> int
extern function aurora_gui_set_callback(widget: int, cb: int)
extern function aurora_gui_quit()

/* ── Test 1: create and show window ── */
function test_window():
    output("--- test_window ---")
    win = aurora_gui_window_new("Aurora Test", 400, 300)
    aurora_gui_window_set_title(win, "Aurora GUI Test")
    aurora_gui_window_resize(win, 500, 400)
    aurora_gui_window_show(win)
    aurora_gui_window_hide(win)
    aurora_gui_window_destroy(win)
    output("Window test done")

/* ── Test 2: create buttons and labels ── */
function test_widgets():
    output("--- test_widgets ---")
    win = aurora_gui_window_new("Widget Test", 300, 200)
    btn = aurora_gui_button_new(win, "Click Me", 10, 10, 100, 30)
    aurora_gui_button_set_text(btn, "Pressed")
    lbl = aurora_gui_label_new(win, "Hello Aurora", 10, 50, 200, 20)
    aurora_gui_label_set_text(lbl, "Updated Label")
    aurora_gui_window_show(win)
    aurora_gui_window_destroy(win)
    output("Widget test done")

/* ── Test 3: textbox ── */
function test_textbox():
    output("--- test_textbox ---")
    win = aurora_gui_window_new("Input Test", 300, 200)
    tb = aurora_gui_textbox_new(win, 10, 10, 200, 25)
    aurora_gui_set_callback(btn, 0)
    aurora_gui_window_show(win)
    aurora_gui_window_destroy(win)
    output("Textbox test done")

/* ── Main ── */
output("=== Phase 3 Cross-Platform GUI Test ===")
test_window()
test_widgets()
test_textbox()
output("=== GUI tests done ===")
