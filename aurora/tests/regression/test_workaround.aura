function _try_fn(fn)
    fn()
end

function assert_throws(fn)
    did_throw = false
    try:
        _try_fn(fn)
    catch e:
        did_throw = true
    end
    if not did_throw
        throw "assert_throws failed: function did not throw"
    end
end

lambda throwing_fn():
    throw "error"
end

lambda safe_fn():
    return 42
end

function main()
    output("test 1: should pass")
    assert_throws(throwing_fn)
    output("test 1 ok")
    
    output("test 2: should throw (via assert_throws)")
    did_catch = false
    try:
        assert_throws(safe_fn)
    catch e:
        did_catch = true
    end
    if did_catch
        output("test 2 ok (caught expected failure)")
    else
        output("test 2 FAIL (did not catch)")
    end
    
    output("DONE")
end
