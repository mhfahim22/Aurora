function try_call(fn)
    did_throw = false
    try:
        fn()
    catch e:
        did_throw = true
    end
    output("after try")
    if did_throw
        output("caught")
    else
        output("not caught")
    end
end

lambda throwing_fn():
    throw "error"
end

function main()
    output("about to try_call")
    try_call(throwing_fn)
    output("DONE")
end
