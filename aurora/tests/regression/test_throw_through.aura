lambda throwing_fn():
    throw "error"
end

function call_lambda(f)
    f()
end

function main()
    output("about to try")
    did_catch = false
    try:
        call_lambda(throwing_fn)
    catch e:
        did_catch = true
    end
    if did_catch
        output("caught it")
    else
        output("NOT caught")
    end
end
