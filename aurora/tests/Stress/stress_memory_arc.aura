# Phase 8: ARC stress test (simplified — no annotation)

function share_chain(n)
    if n <= 0
        return 0
    data = [n]
    result = data[0]
    return result + share_chain(n - 1)

function pipeline(n)
    total = 0
    for i in n
        data = [i, i+1]
        total = total + data[0] + data[1]
    return total

function shared_update(n)
    counter = 0
    for i in n
        counter = counter + 1
    return counter

output(share_chain(200))
output(pipeline(100))
output(shared_update(100))
output("ARC_OK")
