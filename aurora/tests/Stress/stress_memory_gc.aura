# Phase 8: GC stress test
# Creates cyclic references that force GC collection

@gc
function gc_cycle_chain(n)
    if n <= 0
        return 0
    # Allocate objects in a chain
    a = [n]
    b = [n-1]
    c = [n-2]
    result = a[0] + b[0] + c[0]
    return result + gc_cycle_chain(n - 3)

@gc
function gc_many_objects(n)
    total = 0
    for i in n
        # Create temporary objects that GC must collect
        data = [i, i+1, i+2]
        data2 = [data[0], data[1]]
        data3 = [data2[0], i]
        total = total + data3[0] + data3[1]
    return total

@gc
function gc_nested_cycles(n)
    total = 0
    for i in n
        a = [i]
        for j in 3
            b = [a[0], j]
            a = [b[0], b[1]]
        total = total + a[0]
    return total

@gc
function gc_interleaved(n)
    total = 0
    # Rain of allocations interleaved with computation
    for i in n
        x = [i, i+1]
        y = [x[0]]
        z = [y[0], x[1]]
        total = total + z[0] + z[1]
    return total

output(gc_cycle_chain(300))
output(gc_many_objects(5000))
output(gc_nested_cycles(3000))
output(gc_interleaved(5000))
output("GC_OK")
