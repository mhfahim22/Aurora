# Phase 8: Large array stress test
function large_array()
    @arena arr = 0
    @arena total = 0
    arr = []
    for i in 100000
        push(arr, i)
    total = 0
    for i in 10000
        total = total + arr[i]
    return total

function large_nested()
    total = 0
    for i in 1000
        row = []
        for j in 100
            push(row, i * j)
        total = total + row[50]
    return total

function deep_recursion_arr(n)
    @raii result = 0
    result = []
    i = 1
    while i <= n
        push(result, i)
        i = i + 1
    end
    return result

function sum_list(arr, n)
    if n <= 0
        return 0
    return arr[n-1] + sum_list(arr, n-1)

output(large_array())
output(large_nested())
result = deep_recursion_arr(100)
output(sum_list(result, 100))
output("LARGE_ARRAY_OK")
