extern "libtorch_c_api" function tensor_1d(d1: i64, dtype: i32) -> pointer
extern "libtorch_c_api" function tensor_2d(d1: i64, d2: i64, dtype: i32) -> pointer
extern "libtorch_c_api" function tensor_randn_2d(rows: i64, cols: i64) -> pointer
extern "libtorch_c_api" function tensor_zeros_2d(rows: i64, cols: i64) -> pointer
extern "libtorch_c_api" function tensor_ones_2d(rows: i64, cols: i64) -> pointer
extern "libtorch_c_api" function tensor_arange(start: i64, end: i64, step: i64) -> pointer
extern "libtorch_c_api" function tensor_item_float(tensor: pointer) -> f64
extern "libtorch_c_api" function tensor_item_int(tensor: pointer) -> i64
extern "libtorch_c_api" function tensor_destroy(tensor: pointer) -> void
extern "libtorch_c_api" function tensor_ndim(tensor: pointer) -> i32
extern "libtorch_c_api" function tensor_size(tensor: pointer, dim: i32) -> i64
extern "libtorch_c_api" function tensor_numel(tensor: pointer) -> i64
extern "libtorch_c_api" function tensor_print(tensor: pointer) -> void
extern "libtorch_c_api" function tensor_add(a: pointer, b: pointer) -> pointer
extern "libtorch_c_api" function tensor_sub(a: pointer, b: pointer) -> pointer
extern "libtorch_c_api" function tensor_mul(a: pointer, b: pointer) -> pointer
extern "libtorch_c_api" function tensor_matmul(a: pointer, b: pointer) -> pointer
extern "libtorch_c_api" function tensor_add_scalar(a: pointer, s: f64) -> pointer
extern "libtorch_c_api" function tensor_mul_scalar(a: pointer, s: f64) -> pointer
extern "libtorch_c_api" function tensor_relu(a: pointer) -> pointer
extern "libtorch_c_api" function tensor_sigmoid(a: pointer) -> pointer
extern "libtorch_c_api" function tensor_tanh(a: pointer) -> pointer
extern "libtorch_c_api" function tensor_softmax(a: pointer, dim: i32) -> pointer
extern "libtorch_c_api" function tensor_transpose_2d(a: pointer) -> pointer
extern "libtorch_c_api" function tensor_flatten(a: pointer) -> pointer
extern "libtorch_c_api" function cuda_is_available() -> i32

function main():
    output("=== ones(2,3) ===\n")
    t = tensor_ones_2d(2, 3)
    tensor_print(t)

    output("ndim: ")
    output(tensor_ndim(t))
    output("\nsize: ")
    output(tensor_size(t, 0))
    output(tensor_size(t, 1))
    output("\nnumel: ")
    output(tensor_numel(t))

    output("\n=== 1+1=2 ===\n")
    a = tensor_ones_2d(2, 3)
    b = tensor_ones_2d(2, 3)
    c = tensor_add(a, b)
    tensor_print(c)

    output("\n=== scalar ops ===\n")
    six = tensor_mul_scalar(c, 2.0)
    tensor_print(six)

    output("\n=== matmul ===\n")
    m1 = tensor_randn_2d(2, 3)
    m2 = tensor_randn_2d(3, 2)
    mm = tensor_matmul(m1, m2)
    tensor_print(mm)

    output("\n=== arange ===\n")
    ar = tensor_arange(0, 10, 2)
    tensor_print(ar)

    output("\n=== activations ===\n")
    neg = tensor_randn_2d(1, 4)
    tensor_print(neg)
    r = tensor_relu(neg)
    tensor_print(r)
    sg = tensor_sigmoid(r)
    tensor_print(sg)
    th = tensor_tanh(sg)
    tensor_print(th)
    sm = tensor_softmax(th, 1)
    tensor_print(sm)

    output("\n=== transpose + flatten ===\n")
    tp = tensor_transpose_2d(t)
    tensor_print(tp)
    fl = tensor_flatten(t)
    tensor_print(fl)

    output("\n=== zeros + scalar ===\n")
    z = tensor_zeros_2d(2, 2)
    z2 = tensor_add_scalar(z, 5.0)
    tensor_print(z2)

    output("\nCUDA: ")
    output(cuda_is_available())
    output("\n")

    tensor_destroy(t)
    tensor_destroy(a)
    tensor_destroy(b)
    tensor_destroy(c)
    tensor_destroy(six)
    tensor_destroy(m1)
    tensor_destroy(m2)
    tensor_destroy(mm)
    tensor_destroy(ar)
    tensor_destroy(neg)
    tensor_destroy(r)
    tensor_destroy(sg)
    tensor_destroy(th)
    tensor_destroy(sm)
    tensor_destroy(tp)
    tensor_destroy(fl)
    tensor_destroy(z)
    tensor_destroy(z2)

    output("=== All tests passed ===\n")
    return 0
