extern "cpp_interop_test" function add(a: f64, b: f64) -> f64
extern "cpp_interop_test" function sub(a: f64, b: f64) -> f64
extern "cpp_interop_test" function mul(a: f64, b: f64) -> f64
extern "cpp_interop_test" function power(base: f64, exp: f64) -> f64

extern "cpp_interop_test" function vec_new() -> pointer
extern "cpp_interop_test" function vec_delete(v: pointer) -> void
extern "cpp_interop_test" function vec_push(v: pointer, val: f64) -> void
extern "cpp_interop_test" function vec_get(v: pointer, idx: i32) -> f64
extern "cpp_interop_test" function vec_size(v: pointer) -> i32
extern "cpp_interop_test" function vec_sum(v: pointer) -> f64

extern "cpp_interop_test" function string_from_cstr(s: cstring) -> pointer
extern "cpp_interop_test" function string_delete(s: pointer) -> void
extern "cpp_interop_test" function string_length(s: pointer) -> i32
extern "cpp_interop_test" function string_cstr(s: pointer) -> cstring
extern "cpp_interop_test" function string_print(s: pointer) -> void

extern "cpp_interop_test" function counter_new() -> pointer
extern "cpp_interop_test" function counter_new_start(start: i64) -> pointer
extern "cpp_interop_test" function counter_delete(c: pointer) -> void
extern "cpp_interop_test" function counter_inc(c: pointer) -> i64
extern "cpp_interop_test" function counter_dec(c: pointer) -> i64
extern "cpp_interop_test" function counter_add(c: pointer, n: i64) -> i64
extern "cpp_interop_test" function counter_get(c: pointer) -> i64
extern "cpp_interop_test" function counter_reset(c: pointer) -> void

function main():
    output("=== C++ Interop Test ===\n")
    output("--- Math ---\n")
    r1 = add(10.0, 20.0)
    output("10+20=")
    output(r1)
    output("\n")

    r2 = sub(100.0, 30.0)
    output("100-30=")
    output(r2)
    output("\n")

    r3 = mul(7.0, 8.0)
    output("7*8=")
    output(r3)
    output("\n")

    r4 = power(2.0, 10.0)
    output("2^10=")
    output(r4)
    output("\n")

    output("--- std::vector ---\n")
    v = vec_new()
    vec_push(v, 10.0)
    vec_push(v, 20.0)
    vec_push(v, 30.0)

    output("size=")
    output(vec_size(v))
    output("\n")
    output("vec[0]=")
    output(vec_get(v, 0))
    output("\n")
    output("vec[1]=")
    output(vec_get(v, 1))
    output("\n")
    output("sum=")
    output(vec_sum(v))
    output("\n")

    output("--- std::string ---\n")
    s = string_from_cstr("Hello from C++!")
    output("length=")
    output(string_length(s))
    output("\n")

    output("--- Counter class ---\n")
    c = counter_new_start(100)
    output("initial=")
    output(counter_get(c))
    output("\n")

    v1 = counter_inc(c)
    output("after inc=")
    output(v1)
    output("\n")

    v2 = counter_add(c, 50)
    output("after +50=")
    output(v2)
    output("\n")

    counter_reset(c)
    output("after reset=")
    output(counter_get(c))
    output("\n")

    output("--- Cleanup ---\n")
    vec_delete(v)
    string_delete(s)
    counter_delete(c)

    output("=== All C++ interop tests passed ===\n")
    return 0
