# ═══════════════════════════════════════
# 1. ENCAPSULATION
# ═══════════════════════════════════════
class BankAccount
    balance = 0
    owner = "unknown"
    function deposit(amount)
        self.balance = self.balance + amount
    function get_balance()
        output(self.owner + " balance: ")
        output(self.balance)
a = BankAccount(1000, "Alice")
a.deposit(500)
a.get_balance()
# ═══════════════════════════════════════
# 2. INHERITANCE
# ═══════════════════════════════════════
class Animal
    name = "unknown"
    sound = "..."
    function speak()
        output(self.name + " says " + self.sound)
class Dog extends Animal
    breed = "unknown"
    function info()
        output(self.name + " is a " + self.breed)
d = Dog("Rex", "Woof", "Labrador")
d.speak()
d.info()
# ═══════════════════════════════════════
# 3. POLYMORPHISM
# ═══════════════════════════════════════
class Shape
    color = "white"
    function describe()
        output("Shape color: " + self.color)
class Circle extends Shape
    radius = 0
    function describe()
        output("Circle, color: " + self.color)
class Rectangle extends Shape
    width = 0
    function describe()
        output("Rectangle, color: " + self.color)
s = Shape("red")
c = Circle("blue", 5)
r = Rectangle("green", 10)
s.describe()
c.describe()
r.describe()
# ═══════════════════════════════════════
# 4. ABSTRACTION
# ═══════════════════════════════════════
class Vehicle
    brand = "unknown"
    speed = 0
    function accelerate(amount)
        self.speed = self.speed + amount
    function status()
        output(self.brand + " speed: ")
        output(self.speed)
class Car extends Vehicle
    doors = 4
    function honk()
        output(self.brand + " beep beep!")
car = Car("Toyota", 0, 4)
car.accelerate(60)
car.honk()
car.status()
