# ── Test 1: copy scalar ──
x = 10
y = copy x
output(x)   # 10  (source unchanged)
output(y)   # 10

# ── Test 2: copy array ──
arr = [1, 2, 3]
arr2 = copy arr
output(arr)    # [1, 2, 3]
output(arr2)   # [1, 2, 3]

# ── Test 3: free scalar ──
a = 42
free a
# output(a)  ← এটা compile error হবে (poisoned)

# ── Test 4: free array ──
buf = [10, 20, 30]
free buf
# output(buf)  ← compile error

# ── Test 5: delete ──
z = 99
delete z
# output(z)  ← compile error

output(1)   # program এখনো চলছে = 1
