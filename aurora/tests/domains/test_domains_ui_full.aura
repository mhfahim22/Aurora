# Phase 8: UI framework full integration test
# Tests component lifecycle, rendering, styles, routing, animations

function test_component_lifecycle()
    c = component("test")
    output(c != null)
    set_state(c, {"count": 0})
    s = get_state(c, "count")
    output(s == 0)
    render(c, fn() -> "hello")
    destroy(c)

function test_component_tree()
    parent = component("parent")
    child = component("child")
    add_child(parent, child)
    output(1)
    destroy(parent)

function test_style()
    s = style({
        "color": "red",
        "font-size": "16px"
    })
    output(s != null)

function test_theme()
    t = theme({
        "primary": "#007bff",
        "secondary": "#6c757d"
    })
    output(t != null)

function test_route()
    page("/home", fn() -> "home")
    output(1)

function test_layout()
    layout = column()
    output(layout != null)

function test_animation_transition()
    c = component("anim")
    animate(c, "fade", 0, 1, 0.5)
    transition(c, "color", "red", "blue", 0.3)
    destroy(c)
    output(1)

function test_page()
    page("/about", fn() -> "about")
    output(1)

function test_nested_render()
    parent = component("parent")
    render(parent, fn()
        child = component("child")
        render(child, fn() -> "nested")
        return "parent"
    )
    destroy(parent)
    output(1)

function test_state_updates()
    c = component("counter")
    set_state(c, {"count": 0})
    for i in 10
        s = get_state(c, "count")
        set_state(c, {"count": s + 1})
    final = get_state(c, "count")
    output(final == 10)
    destroy(c)

output(0)
test_component_lifecycle()
test_component_tree()
test_style()
test_theme()
test_route()
test_layout()
test_animation_transition()
test_page()
test_nested_render()
test_state_updates()
output("UI_FULL_OK")
