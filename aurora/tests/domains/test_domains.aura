# ── Game Engine ──
output("--- Game Engine ---")
scene main:
    entity player:
        output("entity created")
    physics step:
        output("physics running")

# ── Backend ──
output("--- Backend ---")
server my_server = 8080:
    api "/":
        output("api ready")
    route "/api/hello":
        output("route registered")

