# Test: Domain-specific — Game Engine
# Covers: scene, entity, sprite, camera, physics, collision, audio,
#         animation, input, update, tick, object

function run_game_tests()
    output("--- Game Engine Tests ---")

    scene main:
        entity player:
            output("player created")

        sprite hero:
            output("sprite created")

        camera view:
            output("camera created")

        physics step:
            output("physics step")

        collision check:
            output("collision check")

        audio bgm:
            output("audio played")

        animation walk:
            output("animation set")

        input 0:
            output("input handled")

        update:
            output("update tick")

        tick:
            output("tick dispatch")

        object crate:
            output("object created")

run_game_tests()
output("game engine passed")
