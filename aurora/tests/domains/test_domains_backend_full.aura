# Phase 8: Backend framework full integration test
# Tests server lifecycle, middleware, cache, session, auth, CORS, DB

function test_server_lifecycle()
    s = server(8080)
    output(s != null)
    api(s, "/health", "get", fn() -> "ok")
    start_server(s)
    # Server started — would need curl to test
    stop_server(s)
    output(1)

function test_middleware()
    s = server(8081)
    use(s, fn(req, next) -> next(req))
    api(s, "/test", "get", fn() -> "passed")
    start_server(s)
    stop_server(s)
    output(1)

function test_cache()
    c = cache(100)
    set(c, "key1", "value1")
    v = get(c, "key1")
    output(v == "value1")
    has_k = has(c, "key1")
    output(has_k)
    has_k2 = has(c, "nonexistent")
    output(!has_k2)
    delete(c, "key1")
    has_k3 = has(c, "key1")
    output(!has_k3)
    free(c)

function test_session()
    s = session("abc123")
    set(s, "user", "alice")
    u = get(s, "user")
    output(u == "alice")
    is_exp = is_expired(s)
    output(!is_exp)
    free(s)

function test_auth()
    token = sign("user:admin")
    output(len(token) > 0)
    verified = verify(token)
    output(verified)
    hash = hash_pwd("mypassword")
    output(len(hash) > 0)

function test_cors()
    s = server(8082)
    cors(s, "*")
    api(s, "/data", "get", fn() -> "data")
    start_server(s)
    stop_server(s)
    output(1)

function test_db()
    query("CREATE TABLE users (id, name, email)")
    query("INSERT INTO users VALUES ('1', 'alice', 'alice@test.com')")
    query("INSERT INTO users VALUES ('2', 'bob', 'bob@test.com')")
    r = query("SELECT * FROM users WHERE id = '1'")
    output(len(r) > 0)
    query("DROP TABLE users")

function test_rate_limit()
    s = server(8083)
    limit(s, 100, 60)
    api(s, "/limited", "get", fn() -> "ok")
    start_server(s)
    stop_server(s)
    output(1)

function test_route_group()
    s = server(8084)
    group(s, "/api")
    api(s, "/users", "get", fn() -> "users")
    end_group(s)
    start_server(s)
    stop_server(s)
    output(1)

function test_stream()
    s = server(8085)
    stream(s, "/events", fn() -> "data")
    start_server(s)
    stop_server(s)
    output(1)

function test_metrics()
    s = server(8086)
    metrics(s, "/stats")
    api(s, "/app", "get", fn() -> "app")
    start_server(s)
    stop_server(s)
    output(1)

function test_events()
    ev = event("user.login")
    on(ev, fn(data) -> output(data))
    emit(ev, "alice")

function test_serialize()
    data = {"name": "test", "value": 42}
    json = to_json(data)
    output(len(json) > 0)
    back = from_json(json)
    output(back != null)

output(0)
test_server_lifecycle()
test_middleware()
test_cache()
test_session()
test_auth()
test_cors()
test_db()
test_rate_limit()
test_route_group()
test_stream()
test_metrics()
test_serialize()
output("BACKEND_FULL_OK")
