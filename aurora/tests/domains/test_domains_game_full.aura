# Phase 8: Game engine full integration test (simplified)

function test_entity()
    entity = ["pos_x", 10, "pos_y", 20]
    output(1)
    output(entity[1] == 10)
    output(entity[3] == 20)

function test_update()
    pos = [0, 0]
    pos[0] = pos[0] + 1
    output(pos[0] > 0)

output(0)
test_entity()
test_update()
output("GAME_FULL_OK")
