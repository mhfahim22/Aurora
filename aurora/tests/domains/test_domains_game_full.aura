# Phase 8: Game engine full integration test
# Tests scene, entity, physics, audio, input, animation

function test_entity_lifecycle()
    s = scene()
    e = entity(s)
    output(e != null)
    set_pos(e, 10, 20, 0)
    px = get_pos_x(e)
    py = get_pos_y(e)
    output(px == 10)
    output(py == 20)
    destroy(e)
    shutdown(s)

function test_entity_velocity()
    s = scene()
    e = entity(s)
    set_pos(e, 0, 0, 0)
    set_velocity(e, 5, 10, 0)
    vx = get_velocity_x(e)
    vy = get_velocity_y(e)
    output(vx == 5)
    output(vy == 10)
    destroy(e)
    shutdown(s)

function test_sprite()
    s = scene()
    e = entity(s)
    spr = sprite(e, "@")
    output(spr != null)
    destroy(e)
    shutdown(s)

function test_camera()
    s = scene()
    cam = camera(s, 0, 0, 800, 600)
    output(cam != null)
    shutdown(s)

function test_physics()
    s = scene()
    set_gravity(0, -9.8, 0)
    output(1)
    shutdown(s)

function test_audio()
    play_tone(440, 200)
    output(1)

function test_animation()
    s = scene()
    e = entity(s)
    anim = animation(e, "bounce", 0, 100, 1.0)
    output(anim != null)
    destroy(e)
    shutdown(s)

function test_input()
    keys = poll_input()
    output(len(keys) == 256)
    down = is_key_down(keys, 32)  # space key
    output(down == 0)  # probably not pressed

function test_update()
    s = scene()
    e = entity(s)
    set_pos(e, 0, 0, 0)
    set_velocity(e, 1, 0, 0)
    for i in 10
        tick(s, 0.016)
    px = get_pos_x(e)
    output(px > 0)
    destroy(e)
    shutdown(s)

function test_object()
    s = scene()
    obj = object(s, "wall", 100, 200, 50, 50)
    output(obj != null)
    shutdown(s)

output(0)
test_entity_lifecycle()
test_entity_velocity()
test_sprite()
test_camera()
test_physics()
test_audio()
test_animation()
test_input()
test_update()
test_object()
output("GAME_FULL_OK")
