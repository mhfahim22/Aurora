# Test: Domain-specific — UI Framework
# Covers: component, state, properties, render, style, theme,
#         route, page, layout, animate, transition

function run_ui_tests()
    output("--- UI Framework Tests ---")

    component my_comp:
        state count = 0
        output("state allocated")

        properties size:
            width = 100
            height = 200
        output("properties defined")

        render:
            output("render called")

    style button:
        output("style applied")

    theme dark:
        output("theme set")

    route "/home":
        output("route registered")

    page dashboard:
        output("page registered")

    layout vertical:
        output("layout created")

    animate fade:
        output("animation played")

    transition slide:
        output("transition set")

run_ui_tests()
output("ui tests passed")
