outputln("Testing 3 routes (both in last)...")
server app
    route "GET" "/list"
        json(aurora_todo_list())
    route "POST" "/create"
        body = request("body")
        json(aurora_todo_create(body))
    route "PUT" "/update/:id"
        id = request.params.id
        body = request("body")
        json(aurora_todo_update(id, body, 0))
outputln("Server registered.")
