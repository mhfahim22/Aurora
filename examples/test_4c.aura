outputln("Testing 4 routes (PUT at pos 3)...")
server app
    route "GET" "/todos"
        json(aurora_todo_list())
    route "POST" "/todos"
        body = request("body")
        json(aurora_todo_create(body))
    route "PUT" "/todos/:id"
        id = request.params.id
        body = request("body")
        json(aurora_todo_update(id, body, 0))
    route "GET" "/todos/:id"
        id = request.params.id
        json(aurora_todo_get(id))
outputln("Server registered.")
