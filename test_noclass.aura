function fib(n, memo)
    if n <= 1
        return n
    if memo[n] != null
        return memo[n]
    result = fib(n - 1, memo) + fib(n - 2, memo)
    memo[n] = result
    return result

memo = []
for i in 56
    memo = push(memo, null)

result = fib(55, memo)
output("fib(55) = " + result)

function stress_arena()
    i = 0
    while i < 500
        @arena batch = []
        j = 0
        while j < 500
            batch = push(batch, i * j)
            j = j + 1
        sum = 0
        for x in batch
            sum = sum + x
        i = i + 1
    output("arena stress done")

function stress_arc()
    @arc arr = [1, 2, 3, 4, 5]
    copies = []
    for i in 100
        copies = push(copies, arr)
    output("arc stress done, len=" + len(copies))

function apply_twice(x, fn)
    return fn(fn(x))

stress_arena()
stress_arc()
output("ALL TESTS PASSED")
