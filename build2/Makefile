aurora_parser: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles\Makefile2 aurora_parser
.PHONY : aurora_parser

# fast build rule for target.
aurora_parser/fast:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\aurora_parser.dir\build.make CMakeFiles/aurora_parser.dir/build
.PHONY : aurora_parser/fast

