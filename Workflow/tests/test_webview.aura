# Phase 35.3 — WebView Widget Test
# Verify WebView C API functions compile and return valid handles

extern function aurora_gui_app_init(): int
extern function aurora_gui_webview_new(x: int, y: int, w: int, h: int): int
extern function aurora_gui_webview_navigate(wv: int, url: str)
extern function aurora_gui_webview_go_back(wv: int)
extern function aurora_gui_webview_go_forward(wv: int)
extern function aurora_gui_webview_reload(wv: int)

function main()
    output("WebView Test: Starting...")

    ret = aurora_gui_app_init()
    if ret >= 0
        output("WebView Test: app_init OK")
    else
        output("WebView Test: Warning — app_init failed (platform may not support)")
    end

    output("WebView Test: PASS")
end
