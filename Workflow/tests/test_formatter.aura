# Phase 35.4 — Code Formatter Test
# Verify formatter C API compiles and runs

extern function aurora_dev_format(code: str) -> str

function main()
    output("Formatter Test: Starting...")

    source = "function add(a,b){return a+b}"
    fmt = aurora_dev_format(source)

    if fmt == ""
        output("Formatter Test: Warning — format returned empty")
    else
        output("Formatter Test: Format returned " + fmt)
    end

    output("Formatter Test: PASS")
end
