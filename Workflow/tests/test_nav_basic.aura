# Navigation Basic Test
# Verifies init, register screens, push, pop, destroy

extern function aurora_app_nav_init() -> ptr
extern function aurora_app_nav_destroy(nav: ptr)
extern function aurora_app_nav_register(nav: ptr, name: string, screen: ptr)
extern function aurora_app_nav_push(nav: ptr, name: string) -> int
extern function aurora_app_nav_pop(nav: ptr) -> int
extern function aurora_app_nav_replace(nav: ptr, name: string) -> int
extern function aurora_app_nav_current(nav: ptr) -> string
extern function aurora_app_nav_depth(nav: ptr) -> int
extern function aurora_app_nav_set_on_change(nav: ptr, cb: ptr)

function main()
    nav = aurora_app_nav_init()
    if nav == 0
        output("FAIL: nav_init returned null")
        return
    end

    aurora_app_nav_register(nav, "screen1", 0)
    aurora_app_nav_register(nav, "screen2", 0)
    aurora_app_nav_register(nav, "screen3", 0)

    result = aurora_app_nav_push(nav, "screen1")
    if result != 0
        output("FAIL: nav_push returned " + str(result))
        return
    end

    depth = aurora_app_nav_depth(nav)
    if depth != 1
        output("FAIL: depth expected 1 got " + str(depth))
        return
    end

    result = aurora_app_nav_pop(nav)
    if result != 0
        output("FAIL: nav_pop returned " + str(result))
        return
    end

    depth = aurora_app_nav_depth(nav)
    if depth != 0
        output("FAIL: depth after pop expected 0 got " + str(depth))
        return
    end

    aurora_app_nav_destroy(nav)
    output("PASS")
end
