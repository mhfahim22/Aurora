extern function aurora_gui_window_new(title: cstring, width: int, height: int) -> pointer
extern function aurora_gui_window_destroy(win: pointer)
extern function aurora_gui_passwordbox_new(parent: pointer, x: int, y: int, w: int, h: int) -> pointer
extern function aurora_gui_passwordbox_set_text(pb: pointer, text: cstring)
extern function aurora_gui_passwordbox_get_text(pb: pointer) -> cstring

function main()
    output("password: start")
    win = aurora_gui_window_new("PwTest", 400, 200)
    if win == null
        output("  note: window_new returned null (headless)")
    end

    pb = aurora_gui_passwordbox_new(win, 10, 10, 200, 30)
    if pb == null
        output("  note: passwordbox_new returned null (headless)")
    end

    aurora_gui_passwordbox_set_text(pb, "secret123")
    aurora_gui_window_destroy(win)
    output("password: PASS")
end
