## Layout Combined (all properties) Unit Tests

extern function aurora_app_layout_create() -> ptr
extern function aurora_app_layout_destroy(layout: ptr)
extern function aurora_app_layout_node_new(parent: ptr, typ: int) -> ptr
extern function aurora_app_layout_node_set_direction(node: ptr, direction: int)
extern function aurora_app_layout_node_set_justify(node: ptr, justify: int)
extern function aurora_app_layout_node_set_align(node: ptr, align: int)
extern function aurora_app_layout_node_set_wrap(node: ptr, wrap: int)
extern function aurora_app_layout_node_set_gap(node: ptr, gap: double)
extern function aurora_app_layout_node_set_size(node: ptr, w: double, h: double)
extern function aurora_app_layout_node_set_min_size(node: ptr, w: double, h: double)
extern function aurora_app_layout_node_set_max_size(node: ptr, w: double, h: double)
extern function aurora_app_layout_node_set_padding(node: ptr, l: double, t: double, r: double, b: double)
extern function aurora_app_layout_node_set_margin(node: ptr, l: double, t: double, r: double, b: double)
extern function aurora_app_layout_calculate(root: ptr, width: double, height: double)
extern function aurora_app_layout_node_get_x(node: ptr) -> double
extern function aurora_app_layout_node_get_y(node: ptr) -> double
extern function aurora_app_layout_node_get_w(node: ptr) -> double
extern function aurora_app_layout_node_get_h(node: ptr) -> double
extern function aurora_app_layout_node_set_flex(node: ptr, grow: int, shrink: int, basis: int)

function main()
    output("═══ Layout Combined Test ═══")

    output("  setup root: start")
    lay = aurora_app_layout_create()
    if lay == 0
        output("FAIL: layout_create returned null")
        return
    end
    root = aurora_app_layout_node_new(0, 0)
    if root == 0
        output("FAIL: node_new root returned null")
        aurora_app_layout_destroy(lay)
        return
    end
    aurora_app_layout_node_set_direction(root, 0)
    aurora_app_layout_node_set_justify(root, 0)
    aurora_app_layout_node_set_align(root, 3)
    aurora_app_layout_node_set_wrap(root, 0)
    aurora_app_layout_node_set_size(root, 600.0, 200.0)
    aurora_app_layout_node_set_min_size(root, 200.0, 100.0)
    aurora_app_layout_node_set_max_size(root, 800.0, 400.0)
    aurora_app_layout_node_set_padding(root, 10.0, 10.0, 10.0, 10.0)
    aurora_app_layout_node_set_gap(root, 8.0)
    output("  setup root: pass")

    output("  create child1 with flex margin: start")
    c1 = aurora_app_layout_node_new(root, 0)
    if c1 == 0
        output("FAIL: node_new c1 returned null")
        aurora_app_layout_destroy(lay)
        return
    end
    aurora_app_layout_node_set_flex(c1, 1, 0, 0)
    aurora_app_layout_node_set_size(c1, 0.0, 80.0)
    aurora_app_layout_node_set_min_size(c1, 50.0, 40.0)
    aurora_app_layout_node_set_margin(c1, 5.0, 5.0, 5.0, 5.0)
    output("  create child1 with flex margin: pass")

    output("  create child2 with flex padding: start")
    c2 = aurora_app_layout_node_new(root, 0)
    if c2 == 0
        output("FAIL: node_new c2 returned null")
        aurora_app_layout_destroy(lay)
        return
    end
    aurora_app_layout_node_set_flex(c2, 2, 0, 0)
    aurora_app_layout_node_set_size(c2, 0.0, 80.0)
    aurora_app_layout_node_set_padding(c2, 4.0, 4.0, 4.0, 4.0)
    output("  create child2 with flex padding: pass")

    output("  create child3 fixed size: start")
    c3 = aurora_app_layout_node_new(root, 0)
    if c3 == 0
        output("FAIL: node_new c3 returned null")
        aurora_app_layout_destroy(lay)
        return
    end
    aurora_app_layout_node_set_size(c3, 100.0, 80.0)
    output("  create child3 fixed size: pass")

    output("  create grandchild nested: start")
    inner = aurora_app_layout_node_new(c2, 0)
    if inner == 0
        output("FAIL: node_new inner returned null")
        aurora_app_layout_destroy(lay)
        return
    end
    aurora_app_layout_node_set_direction(inner, 1)
    aurora_app_layout_node_set_size(inner, 0.0, 0.0)
    aurora_app_layout_node_set_flex(inner, 0, 0, 0)
    gc1 = aurora_app_layout_node_new(inner, 0)
    aurora_app_layout_node_set_size(gc1, 40.0, 20.0)
    gc2 = aurora_app_layout_node_new(inner, 0)
    aurora_app_layout_node_set_size(gc2, 40.0, 20.0)
    aurora_app_layout_node_set_gap(inner, 4.0)
    output("  create grandchild nested: pass")

    output("  calculate: start")
    aurora_app_layout_calculate(root, 600.0, 200.0)
    output("  calculate: pass")

    output("  verify positions: start")
    rw = aurora_app_layout_node_get_w(root)
    rh = aurora_app_layout_node_get_h(root)
    output("  root w=" + str(rw) + " h=" + str(rh))
    if rw == 0
        output("  (stub: root width=0)")
    end

    c1x = aurora_app_layout_node_get_x(c1)
    c1y = aurora_app_layout_node_get_y(c1)
    c1w = aurora_app_layout_node_get_w(c1)
    c1h = aurora_app_layout_node_get_h(c1)
    output("  c1 x=" + str(c1x) + " y=" + str(c1y) + " w=" + str(c1w) + " h=" + str(c1h))

    c2x = aurora_app_layout_node_get_x(c2)
    c2y = aurora_app_layout_node_get_y(c2)
    c2w = aurora_app_layout_node_get_w(c2)
    c2h = aurora_app_layout_node_get_h(c2)
    output("  c2 x=" + str(c2x) + " y=" + str(c2y) + " w=" + str(c2w) + " h=" + str(c2h))

    c3x = aurora_app_layout_node_get_x(c3)
    c3y = aurora_app_layout_node_get_y(c3)
    c3w = aurora_app_layout_node_get_w(c3)
    c3h = aurora_app_layout_node_get_h(c3)
    output("  c3 x=" + str(c3x) + " y=" + str(c3y) + " w=" + str(c3w) + " h=" + str(c3h))

    if c1w == c2w
        if c1w != 0
            if c2w != 0
                output("FAIL: flex children should have different widths")
                aurora_app_layout_destroy(lay)
                return
            end
        end
    else
        output("  flex children differ (ok)")
    end

    gcx = aurora_app_layout_node_get_x(gc1)
    gcy = aurora_app_layout_node_get_y(gc1)
    output("  gc1 x=" + str(gcx) + " y=" + str(gcy))
    output("  verify positions: pass")

    output("  destroy: start")
    aurora_app_layout_destroy(lay)
    output("  destroy: pass")

    output("PASS")
end
