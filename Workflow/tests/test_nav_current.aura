# Navigation Current Test
# Verifies current screen updates after push and pop

extern function aurora_app_nav_init() -> ptr
extern function aurora_app_nav_destroy(nav: ptr)
extern function aurora_app_nav_register(nav: ptr, name: string, screen: ptr)
extern function aurora_app_nav_push(nav: ptr, name: string) -> int
extern function aurora_app_nav_pop(nav: ptr) -> int
extern function aurora_app_nav_current(nav: ptr) -> string
extern function aurora_app_nav_depth(nav: ptr) -> int
extern function aurora_app_nav_set_on_change(nav: ptr, cb: ptr)

function main()
    nav = aurora_app_nav_init()
    if nav == 0
        output("FAIL: nav_init returned null")
        return
    end

    aurora_app_nav_register(nav, "screen1", 0)
    aurora_app_nav_register(nav, "screen2", 0)

    result = aurora_app_nav_push(nav, "screen1")
    if result != 0
        output("FAIL: push screen1 returned " + str(result))
        return
    end

    result = aurora_app_nav_push(nav, "screen2")
    if result != 0
        output("FAIL: push screen2 returned " + str(result))
        return
    end

    current = aurora_app_nav_current(nav)
    if starts(current, "screen2")
        if strlen(current) != 7
            output("FAIL: current2 length expected 7 got " + str(strlen(current)))
            return
        end
    else
        output("FAIL: current expected screen2")
        return
    end

    result = aurora_app_nav_pop(nav)
    if result != 0
        output("FAIL: pop returned " + str(result))
        return
    end

    current = aurora_app_nav_current(nav)
    if starts(current, "screen1")
        if strlen(current) != 7
            output("FAIL: current1 length expected 7 got " + str(strlen(current)))
            return
        end
    else
        output("FAIL: after pop current expected screen1")
        return
    end

    aurora_app_nav_destroy(nav)
    output("PASS")
end
