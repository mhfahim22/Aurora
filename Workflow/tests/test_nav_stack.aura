# Navigation Stack Depth Test
# Verifies depth tracking with 5 screens pushed and popped

extern function aurora_app_nav_init() -> ptr
extern function aurora_app_nav_destroy(nav: ptr)
extern function aurora_app_nav_register(nav: ptr, name: string, screen: ptr)
extern function aurora_app_nav_push(nav: ptr, name: string) -> int
extern function aurora_app_nav_pop(nav: ptr) -> int
extern function aurora_app_nav_current(nav: ptr) -> string
extern function aurora_app_nav_depth(nav: ptr) -> int
extern function aurora_app_nav_set_on_change(nav: ptr, cb: ptr)

function main()
    nav = aurora_app_nav_init()
    if nav == 0
        output("FAIL: nav_init returned null")
        return
    end

    aurora_app_nav_register(nav, "s1", 0)
    aurora_app_nav_register(nav, "s2", 0)
    aurora_app_nav_register(nav, "s3", 0)
    aurora_app_nav_register(nav, "s4", 0)
    aurora_app_nav_register(nav, "s5", 0)

    result = aurora_app_nav_push(nav, "s1")
    if result != 0
        output("FAIL: push s1 returned " + str(result))
        return
    end

    result = aurora_app_nav_push(nav, "s2")
    if result != 0
        output("FAIL: push s2 returned " + str(result))
        return
    end

    result = aurora_app_nav_push(nav, "s3")
    if result != 0
        output("FAIL: push s3 returned " + str(result))
        return
    end

    result = aurora_app_nav_push(nav, "s4")
    if result != 0
        output("FAIL: push s4 returned " + str(result))
        return
    end

    result = aurora_app_nav_push(nav, "s5")
    if result != 0
        output("FAIL: push s5 returned " + str(result))
        return
    end

    depth = aurora_app_nav_depth(nav)
    if depth != 5
        output("FAIL: depth expected 5 got " + str(depth))
        return
    end

    result = aurora_app_nav_pop(nav)
    if result != 0
        output("FAIL: pop 1 returned " + str(result))
        return
    end

    result = aurora_app_nav_pop(nav)
    if result != 0
        output("FAIL: pop 2 returned " + str(result))
        return
    end

    result = aurora_app_nav_pop(nav)
    if result != 0
        output("FAIL: pop 3 returned " + str(result))
        return
    end

    result = aurora_app_nav_pop(nav)
    if result != 0
        output("FAIL: pop 4 returned " + str(result))
        return
    end

    result = aurora_app_nav_pop(nav)
    if result != 0
        output("FAIL: pop 5 returned " + str(result))
        return
    end

    depth = aurora_app_nav_depth(nav)
    if depth != 0
        output("FAIL: depth after pop expected 0 got " + str(depth))
        return
    end

    aurora_app_nav_destroy(nav)
    output("PASS")
end
