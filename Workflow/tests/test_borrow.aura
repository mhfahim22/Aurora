# Phase 1.2 — Borrow Checker Test
# Verify ownership rules are enforced at compile time
# Each test case is in its own function so we can see which ones trigger errors

function test_move_after_move()
    x = 42
    y = move x
    z = move x
    output("Should not reach here")
end

function test_use_after_move()
    x = 42
    y = move x
    output(x)
    output("Should not reach here")
end

function test_write_during_borrow()
    x = 42
    b = borrow x
    x = 5
    output("Should not reach here")
end

function test_free_during_borrow()
    x = 42
    b = borrow x
    free x
    output("Should not reach here")
end

function main()
    output("Borrow Test: Starting...")
    test_move_after_move()
    output("Borrow Test: All PASS")
end
