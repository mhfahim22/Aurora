{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aurora",
  "scopeName": "source.aurora",
  "fileTypes": [".aura"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#method-call" },
    { "include": "#lambda" },
    { "include": "#range-operator" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.aurora",
          "match": "#.*$"
        },
        {
          "name": "comment.block.aurora",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.aurora" }
          }
        }
      ]
    },
    "attributes": {
      "name": "entity.other.attribute-name.aurora",
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
      "captures": {
        "0": { "name": "keyword.control.attribute.aurora" }
      }
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aurora",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.aurora" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.aurora" } },
          "patterns": [{ "include": "#string-escapes" }]
        },
        {
          "name": "string.quoted.single.aurora",
          "begin": "'",
          "end": "'",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.aurora" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.aurora" } },
          "patterns": [{ "include": "#string-escapes" }]
        }
      ]
    },
    "string-escapes": {
      "name": "constant.character.escape.aurora",
      "match": "\\\\(n|t|r|\\\\|\"|'|0)"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.aurora",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.aurora",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.aurora",
          "match": "\\b(if|elseif|else|while|for|loop|repeat|until|break|continue|skip|match|case|default|switch|return|yield|pass|end|end\\b)\\b"
        },
        {
          "name": "keyword.control.exception.aurora",
          "match": "\\b(try|catch|finally|throw|ensure|panic)\\b"
        },
        {
          "name": "keyword.declaration.function.aurora",
          "match": "\\b(function|lambda)\\b"
        },
        {
          "name": "keyword.declaration.class.aurora",
          "match": "\\b(class|interface|enum|struct|union|new)\\b"
        },
        {
          "name": "keyword.control.oop.aurora",
          "match": "\\b(private|public|protected|static|final|abstract|extends|implements|override)\\b"
        },
        {
          "name": "keyword.control.async.aurora",
          "match": "\\b(async|await|wait|spawn|parallel|thread|callback|event|signal|emit)\\b"
        },
        {
          "name": "keyword.control.logic.aurora",
          "match": "\\b(and|or|not|xor|equals|in|is|as)\\b"
        },
        {
          "name": "keyword.control.module.aurora",
          "match": "\\b(import|from|alias|global|outer|namespace|module|package|extern|using)\\b"
        },
        {
          "name": "keyword.control.memory.aurora",
          "match": "\\b(delete|copy|move|free|drop|borrow|reference|pointer|shared|weak|constant|mutable|safe|unsafe)\\b"
        },
        {
          "name": "keyword.control.types.aurora",
          "match": "\\b(type|list|map|set|array|tuple|vector|stack|queue|json|typeof|sizeof|convert|clone)\\b"
        },
        {
          "name": "keyword.control.attr.aurora",
          "match": "\\b(performance|inline|noinline|constexpr|component|state|properties|render|style|theme|route|page|layout|animate|transition|server|request|response|api|middleware|database|query|model|cache|session|token|auth|scene|entity|object|sprite|camera|physics|collision|audio|animation|input|update|tick|ai|train|predict|tensor|neural|sleep|time|random)\\b"
        },
        {
          "name": "constant.language.aurora",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.aurora",
          "match": "\\b(output|debug|log)\\b"
        },
        {
          "name": "support.function.string.aurora",
          "match": "\\b(len|strlen|upper|lower|trim|replace|split|join|has|starts|ends|reverse|substr|char|int_to_str|float_to_str)\\b"
        },
        {
          "name": "support.function.math.aurora",
          "match": "\\b(abs|sqrt|floor|ceil|round|pow|clamp|min|max|rand)\\b"
        },
        {
          "name": "support.function.io.aurora",
          "match": "\\b(read_file|write_file|append_file|file_exists|delete_file|copy_file|move_file|cwd|cd|dirname|basename|ext|input)\\b"
        },
        {
          "name": "support.function.collection.aurora",
          "match": "\\b(push|pop|insert|remove|clear|sort|reverse|unique|reserve|contains)\\b"
        },
        {
          "name": "support.function.system.aurora",
          "match": "\\b(os|cpu_count|memory_usage|env|run|exit|now|stamp|measure|bench|profile|trace|fields|methods|install|update|search)\\b"
        },
        {
          "name": "support.function.ai.aurora",
          "match": "\\b(ml_add|ml_train|ml_fit|ml_test|ml_predict|ml_retrain)\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "name": "meta.function.aurora",
          "begin": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.function.aurora" },
            "2": { "name": "entity.name.function.definition.aurora" },
            "3": { "name": "punctuation.definition.parameters.begin.aurora" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.parameters.end.aurora" }
          },
          "patterns": [
            { "include": "#function-parameters" },
            { "include": "#comments" }
          ]
        }
      ]
    },
    "function-parameters": {
      "patterns": [
        {
          "name": "variable.parameter.aurora",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "punctuation.separator.aurora",
          "match": ","
        }
      ]
    },
    "function-call": {
      "name": "meta.function-call.aurora",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
      "captures": {
        "1": { "name": "entity.name.function.aurora" },
        "2": { "name": "punctuation.definition.arguments.begin.aurora" }
      }
    },
    "method-call": {
      "name": "meta.method-call.aurora",
      "match": "(\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
      "captures": {
        "1": { "name": "punctuation.accessor.aurora" },
        "2": { "name": "entity.name.method.aurora" },
        "3": { "name": "punctuation.definition.arguments.begin.aurora" }
      }
    },
    "lambda": {
      "name": "meta.lambda.aurora",
      "match": "\\b(lambda)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.function.aurora" }
      }
    },
    "range-operator": {
      "name": "keyword.operator.range.aurora",
      "match": "\\.\\.\\.?",
      "captures": {
        "0": { "name": "keyword.operator.aurora" }
      }
    },
    "operators": {
      "name": "keyword.operator.aurora",
      "match": "(?:\\+|-|\\*(?!\\*)|/(?!/)|=|==|!=|<=|>=|<|>|!|&&|\\|\\||\\||&|%|\\^|~|\\?|:|->|@(?![a-zA-Z_])|<<|>>)"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.separator.aurora",
          "match": ";"
        },
        {
          "name": "punctuation.definition.brace.aurora",
          "match": "[\\[\\](){}\"]"
        },
        {
          "name": "punctuation.separator.aurora",
          "match": ","
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.aurora",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
