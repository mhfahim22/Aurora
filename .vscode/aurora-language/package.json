{
  "name": "aurora-language",
  "displayName": "Aurora Language",
  "description": "Aurora language support — syntax highlighting, JetBrains Mono auto-install",
  "version": "1.0.0",
  "publisher": "aurora-lang",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:aurora",
    "onCommand:aurora.installFont"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aurora.installFont",
        "title": "Aurora: Install JetBrains Mono Font"
      }
    ],
    "languages": [
      {
        "id": "aurora",
        "aliases": ["Aurora", "aurora"],
        "extensions": [".aura"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aurora",
        "scopeName": "source.aurora",
        "path": "./syntaxes/aurora.tmLanguage.json"
      }
    ]
  }
}
